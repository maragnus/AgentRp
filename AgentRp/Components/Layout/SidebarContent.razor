@implements IDisposable
@inject IChatWorkspaceService ChatWorkspaceService
@inject NavigationManager NavigationManager

<div class="d-flex w-100 h-100 flex-column overflow-hidden">
    <div class="flex-shrink-0 border-bottom px-3 py-3">
        <div class="d-flex align-items-start justify-content-between gap-3">
            <div>
                <a class="text-decoration-none text-body-emphasis" href="" @onclick="HandleNavigateAsync">
                    <span class="fs-5 fw-semibold">Agentic RP</span>
                </a>
            </div>

            @if (ShowCloseButton)
            {
                <button type="button"
                        class="btn-close"
                        aria-label="Close sidebar"
                        @onclick="CloseAsync"></button>
            }
        </div>

        <BusyButton Class="btn btn-primary mt-3 w-100" OnClick="CreateChatAsync" BusyText="Creating chat...">
            <i class="fa-regular fa-plus me-2" aria-hidden="true"></i>
            New Chat
        </BusyButton>

        <InlineAlert Message="@ErrorMessage" CssClass="alert alert-danger mt-3 mb-0" />
    </div>

    <div class="flex-grow-1 overflow-auto px-3 py-3">
        <StorySidebarSection />

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="small text-uppercase text-body-secondary">Chats</span>
            <span class="small text-body-secondary">Starred first</span>
        </div>

        <RecentChatsList OnNavigate="OnNavigate" />
    </div>

    <div class="mt-auto flex-shrink-0 border-top px-3 py-3 text-body-secondary">
        <div class="small fw-semibold">Primary User</div>
        <div class="small">Admin Permissions</div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    [Parameter]
    public bool ShowCloseButton { get; set; }

    private string? ErrorMessage { get; set; }

    public void Dispose()
    {
    }

    private async Task CreateChatAsync()
    {
        ErrorMessage = null;

        try
        {
            var threadId = await ChatWorkspaceService.CreateThreadAsync(CancellationToken.None);
            NavigationManager.NavigateTo($"/chat/{threadId}");
            await CloseAsync();
        }
        catch (Exception)
        {
            ErrorMessage = "Creating a new chat failed.";
        }
    }

    private async Task HandleNavigateAsync()
    {
        await CloseAsync();
    }

    private async Task CloseAsync()
    {
        if (OnNavigate.HasDelegate)
            await OnNavigate.InvokeAsync();
    }
}
