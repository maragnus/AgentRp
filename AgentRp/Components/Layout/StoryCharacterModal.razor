@inject IChatStoryService ChatStoryService
@inject IStoryFieldGuidanceService StoryFieldGuidanceService
@inject ILogger<StoryCharacterModal> Logger

<AppModal IsOpen="IsOpen" Title="Characters" OnClose="CloseAsync">
    @if (_isLoading)
    {
        <div class="d-flex align-items-center gap-3 py-3">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>Loading characters...</span>
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div class="fw-semibold">Character List</div>
                    <button type="button"
                            class="btn btn-outline-primary btn-sm"
                            title="@BuildCreateButtonTitle()"
                            aria-label="@BuildCreateButtonTitle()"
                            disabled="@IsCreatingCharacter"
                            @onclick="BeginCreate">
                        <i class="fa-regular fa-plus" aria-hidden="true"></i>
                    </button>
                </div>

                @if (_characters.Count == 0)
                {
                    <div class="alert alert-light border mb-0">No characters yet.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var character in _characters)
                        {
                            var isSelected = _selectedCharacterId == character.CharacterId;

                            <StoryEntitySelectorListItem Name="@character.Name"
                                                         Summary="@character.Summary"
                                                         IsSelected="@isSelected"
                                                         OnClick="() => SelectCharacter(character.CharacterId)">
                                <StatusContent>
                                    @if (character.IsPresentInScene) 
                                    {
                                        <i class="fa-regular fa-eye"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-eye-slash"></i>
                                    }
                                </StatusContent>
                            </StoryEntitySelectorListItem>
                        }
                    </div>
                }
            </div>

            <div class="col-12 col-lg-8">
                <div class="d-flex flex-column gap-3">
                    <InlineAlert Message="@_errorMessage" />

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-name">Name</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit name guidance"
                                    aria-label="Edit name guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Name)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <input id="story-character-name" class="form-control" @bind="_name" />
                        @RenderGuidanceSummary(StoryEntityFieldKey.Name)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-summary">Summary</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit summary guidance"
                                    aria-label="Edit summary guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Summary)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-character-summary" class="form-control" rows="2" @bind="_summary"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.Summary)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-core-personality">Core Personality</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit core personality guidance"
                                    aria-label="Edit core personality guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.CorePersonality)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-character-core-personality" class="form-control" rows="3" @bind="_corePersonality"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.CorePersonality)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-general-appearance">General Appearance</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit general appearance guidance"
                                    aria-label="Edit general appearance guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.GeneralAppearance)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-character-general-appearance" class="form-control" rows="3" @bind="_generalAppearance"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.GeneralAppearance)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-relationships">Relationships</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit relationships guidance"
                                    aria-label="Edit relationships guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Relationships)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-character-relationships" class="form-control" rows="3" @bind="_relationships"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.Relationships)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-character-preferences">Preferences / Likes / Beliefs</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit preferences guidance"
                                    aria-label="Edit preferences guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.PreferencesBeliefs)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-character-preferences" class="form-control" rows="3" @bind="_preferencesBeliefs"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.PreferencesBeliefs)
                    </div>

                    <div class="form-check">
                        <input id="story-character-presence" class="form-check-input" type="checkbox" @bind="_isPresentInScene" />
                        <label class="form-check-label" for="story-character-presence">Currently in the scene</label>
                    </div>

                    <div class="d-flex flex-wrap justify-content-between gap-2 border-top pt-3">
                        <div class="d-flex gap-2">
                            @if (_selectedCharacterId.HasValue)
                            {
                                <BusyButton Class="btn btn-outline-danger"
                                            IsBusy="_isDeleting"
                                            Disabled="@(_isSaving || _isDeleting)"
                                            BusyText="Deleting..."
                                            OnClick="DeleteAsync">
                                    <i class="fa-regular fa-trash me-2" aria-hidden="true"></i>
                                            Delete
                                </BusyButton>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-outline-primary"
                                    title="@BuildAiButtonTitle()"
                                    aria-label="@BuildAiButtonTitle()"
                                    @onclick="OpenAiAssist">
                                <i class="fa-regular fa-wand-magic-sparkles" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Close</button>
                            <BusyButton Class="btn btn-primary"
                                        IsBusy="_isSaving"
                                        Disabled="@(_isSaving || _isDeleting)"
                                        BusyText="Saving..."
                                        OnClick="SaveAsync">
                                <i class="fa-regular fa-floppy-disk me-2" aria-hidden="true"></i>
                                Save
                            </BusyButton>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</AppModal>

<StoryEntityAiAssistModal ThreadId="ThreadId"
                          IsOpen="_isAiAssistOpen"
                          EntityKind="StoryEntityKind.Character"
                          EntityId="_selectedCharacterId"
                          OnAccepted="HandleAiAcceptedAsync"
                          OnClose="CloseAiAssistAsync" />
<StoryFieldGuidanceModal IsOpen="_isGuidanceOpen"
                         EntityKind="StoryEntityKind.Character"
                         FieldKey="_selectedGuidanceFieldKey"
                         OnSaved="HandleGuidanceSavedAsync"
                         OnClose="CloseGuidanceAsync" />

@code {
    [Parameter]
    public Guid ThreadId { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public Guid? InitialCharacterId { get; set; }

    [Parameter]
    public bool StartInCreateMode { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private bool _isLoading;
    private bool _isSaving;
    private bool _isDeleting;
    private bool _wasOpen;
    private Guid? _loadedThreadId;
    private Guid? _selectedCharacterId;
    private IReadOnlyList<StoryCharacterEditorView> _characters = [];
    private string _name = string.Empty;
    private string _summary = string.Empty;
    private string _generalAppearance = string.Empty;
    private string _corePersonality = string.Empty;
    private string _relationships = string.Empty;
    private string _preferencesBeliefs = string.Empty;
    private bool _isPresentInScene;
    private bool _isAiAssistOpen;
    private bool _isGuidanceOpen;
    private StoryEntityFieldKey _selectedGuidanceFieldKey = StoryEntityFieldKey.Name;
    private IReadOnlyList<StoryEntityFieldGuidanceView> _fieldGuidance = [];
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _wasOpen = false;
            return;
        }

        if (_wasOpen && _loadedThreadId == ThreadId)
            return;

        _wasOpen = true;
        _loadedThreadId = ThreadId;
        await LoadAsync(InitialCharacterId, StartInCreateMode);
    }

    private async Task LoadAsync(Guid? selectedCharacterId = null, bool startInCreateMode = false)
    {
        _isLoading = true;
        try
        {
            _characters = await ChatStoryService.GetCharactersAsync(ThreadId, CancellationToken.None);
            _fieldGuidance = await StoryFieldGuidanceService.GetGuidanceAsync(StoryEntityKind.Character, CancellationToken.None);

            if (startInCreateMode)
            {
                BeginCreate();
                return;
            }

            var targetCharacterId = selectedCharacterId
                ?? _selectedCharacterId
                ?? _characters.FirstOrDefault()?.CharacterId;
            if (targetCharacterId.HasValue)
                SelectCharacter(targetCharacterId.Value);
            else
                BeginCreate();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginCreate()
    {
        _errorMessage = null;
        _selectedCharacterId = null;
        _name = string.Empty;
        _summary = string.Empty;
        _generalAppearance = string.Empty;
        _corePersonality = string.Empty;
        _relationships = string.Empty;
        _preferencesBeliefs = string.Empty;
        _isPresentInScene = false;
    }

    private void SelectCharacter(Guid characterId)
    {
        var character = _characters.FirstOrDefault(x => x.CharacterId == characterId);
        if (character is null)
        {
            BeginCreate();
            return;
        }

        _errorMessage = null;
        _selectedCharacterId = character.CharacterId;
        _name = character.Name;
        _summary = character.Summary;
        _generalAppearance = character.GeneralAppearance;
        _corePersonality = character.CorePersonality;
        _relationships = character.Relationships;
        _preferencesBeliefs = character.PreferencesBeliefs;
        _isPresentInScene = character.IsPresentInScene;
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        _isSaving = true;
        try
        {
            var savedCharacter = await ChatStoryService.UpsertCharacterAsync(
                new UpsertCharacter(
                    ThreadId,
                    _selectedCharacterId,
                    _name,
                    _summary,
                    _generalAppearance,
                    _corePersonality,
                    _relationships,
                    _preferencesBeliefs,
                    _isPresentInScene,
                    false),
                CancellationToken.None);

            await LoadAsync(savedCharacter.CharacterId);
            await NotifyChangedAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving character {CharacterName} failed for chat {ChatId}.", _name, ThreadId);
            _errorMessage = $"Saving character '{BuildDisplayName()}' failed.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!_selectedCharacterId.HasValue)
            return;

        var displayName = BuildDisplayName();
        _errorMessage = null;
        _isDeleting = true;
        try
        {
            await ChatStoryService.DeleteCharacterAsync(new DeleteCharacter(ThreadId, _selectedCharacterId.Value), CancellationToken.None);
            await LoadAsync();
            await NotifyChangedAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Deleting character {CharacterId} failed for chat {ChatId}.", _selectedCharacterId.Value, ThreadId);
            _errorMessage = $"Deleting character '{displayName}' failed.";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task NotifyChangedAsync()
    {
        if (OnChanged.HasDelegate)
            await OnChanged.InvokeAsync();
    }

    private void OpenAiAssist() => _isAiAssistOpen = true;

    private void OpenGuidance(StoryEntityFieldKey fieldKey)
    {
        _selectedGuidanceFieldKey = fieldKey;
        _isGuidanceOpen = true;
    }

    private Task CloseAiAssistAsync()
    {
        _isAiAssistOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseGuidanceAsync()
    {
        _isGuidanceOpen = false;
        return Task.CompletedTask;
    }

    private async Task HandleAiAcceptedAsync(StoryEntityAcceptResult result)
    {
        _isAiAssistOpen = false;
        await LoadAsync(result.EntityId);
        await NotifyChangedAsync();
    }

    private Task CloseAsync() => OnClose.InvokeAsync();

    private bool IsCreatingCharacter => !_selectedCharacterId.HasValue;

    private string BuildDisplayName() => string.IsNullOrWhiteSpace(_name) ? "Untitled Character" : _name.Trim();

    private string BuildCreateButtonTitle() => IsCreatingCharacter
        ? "Already creating a new character"
        : "Add character";

    private string BuildAiButtonTitle() => _selectedCharacterId.HasValue
        ? "Edit character with prompt"
        : "New character from prompt";

    private async Task HandleGuidanceSavedAsync(StoryEntityFieldGuidanceView guidance)
    {
        _isGuidanceOpen = false;
        _fieldGuidance = await StoryFieldGuidanceService.GetGuidanceAsync(StoryEntityKind.Character, CancellationToken.None);
    }

    private RenderFragment RenderGuidanceSummary(StoryEntityFieldKey fieldKey) => builder =>
    {
        var guidance = _fieldGuidance.FirstOrDefault(x => x.FieldKey == fieldKey);
        if (guidance is null)
            return;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "small text-body-secondary mt-1");
        builder.AddContent(2, BuildGuidanceSummary(guidance.Guidance));
        builder.CloseElement();
    };

    private static string BuildGuidanceSummary(StoryFieldGuidance guidance) =>
        $"{FormatGuidanceFormat(guidance.Format)}, {FormatDetail(guidance.LevelOfDetail)}, {guidance.SuggestedLength.Minimum}-{guidance.SuggestedLength.Maximum} {FormatLengthMeasure(guidance.Format)}";

    private static string FormatGuidanceFormat(StoryFieldGuidanceFormat guidanceFormat) => guidanceFormat switch
    {
        StoryFieldGuidanceFormat.Words => "list of words",
        StoryFieldGuidanceFormat.Sentences => "sentences",
        StoryFieldGuidanceFormat.Paragraphs => "paragraphs",
        StoryFieldGuidanceFormat.BulletList => "bullet list",
        _ => guidanceFormat.ToString()
    };

    private static string FormatDetail(StoryFieldGuidanceDetailLevel detailLevel) => detailLevel switch
    {
        StoryFieldGuidanceDetailLevel.Simple => "simple",
        StoryFieldGuidanceDetailLevel.Medium => "medium detail",
        StoryFieldGuidanceDetailLevel.Detailed => "detailed",
        _ => detailLevel.ToString()
    };

    private static string FormatLengthMeasure(StoryFieldGuidanceFormat guidanceFormat) => guidanceFormat switch
    {
        StoryFieldGuidanceFormat.Words => "words",
        StoryFieldGuidanceFormat.Sentences => "sentences",
        StoryFieldGuidanceFormat.Paragraphs => "paragraphs",
        StoryFieldGuidanceFormat.BulletList => "items",
        _ => guidanceFormat.ToString().ToLowerInvariant()
    };
}
