@inject IChatStoryService ChatStoryService
@inject IStoryFieldGuidanceService StoryFieldGuidanceService
@inject ILogger<StoryItemsModal> Logger

<AppModal IsOpen="IsOpen" Title="Items" OnClose="CloseAsync">
    @if (_isLoading)
    {
        <div class="d-flex align-items-center gap-3 py-3">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>Loading items...</span>
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div class="fw-semibold">Story Items</div>
                    <button type="button"
                            class="btn btn-outline-primary btn-sm"
                            title="@BuildCreateButtonTitle()"
                            aria-label="@BuildCreateButtonTitle()"
                            disabled="@IsCreatingItem"
                            @onclick="BeginCreate">
                        <i class="fa-regular fa-plus" aria-hidden="true"></i>
                    </button>
                </div>

                @if (_items.Count == 0)
                {
                    <div class="alert alert-light border mb-0">No items yet.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var item in _items)
                        {
                            var isSelected = _selectedItemId == item.ItemId;

                            <StoryEntitySelectorListItem Name="@item.Name"
                                                         Summary="@item.Summary"
                                                         IsSelected="@isSelected"
                                                         OnClick="() => SelectItem(item.ItemId)">
                                <StatusContent>
                                    <span class="badge @(item.IsPresentInScene ? "text-bg-success" : "text-bg-light border text-body-secondary")">
                                        @(item.IsPresentInScene ? "In Scene" : "Stored")
                                    </span>
                                </StatusContent>
                            </StoryEntitySelectorListItem>
                        }
                    </div>
                }
            </div>

            <div class="col-12 col-lg-8">
                <div class="d-flex flex-column gap-3">
                    <InlineAlert Message="@_errorMessage" />

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-item-name">Name</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit name guidance"
                                    aria-label="Edit name guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Name)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <input id="story-item-name" class="form-control" @bind="_name" />
                        @RenderGuidanceSummary(StoryEntityFieldKey.Name)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-item-summary">Summary</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit summary guidance"
                                    aria-label="Edit summary guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Summary)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-item-summary" class="form-control" rows="2" @bind="_summary"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.Summary)
                    </div>

                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <label class="form-label mb-0" for="story-item-details">Details</label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit details guidance"
                                    aria-label="Edit details guidance"
                                    @onclick='() => OpenGuidance(StoryEntityFieldKey.Details)'>
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        </div>
                        <textarea id="story-item-details" class="form-control" rows="4" @bind="_details"></textarea>
                        @RenderGuidanceSummary(StoryEntityFieldKey.Details)
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="story-item-owner">Owner Character</label>
                            <select id="story-item-owner" class="form-select" @bind="_ownerCharacterIdText">
                                <option value="">No owner</option>
                                @foreach (var character in _characters)
                                {
                                    <option value="@character.CharacterId">@character.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="story-item-location">Stored Location</label>
                            <select id="story-item-location" class="form-select" @bind="_locationIdText">
                                <option value="">No location</option>
                                @foreach (var location in _locations)
                                {
                                    <option value="@location.LocationId">@location.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-check">
                        <input id="story-item-presence" class="form-check-input" type="checkbox" @bind="_isPresentInScene" />
                        <label class="form-check-label" for="story-item-presence">Currently in the scene</label>
                    </div>

                    <div class="d-flex flex-wrap justify-content-between gap-2 border-top pt-3">
                        <div class="d-flex gap-2">
                            @if (_selectedItemId.HasValue)
                            {
                                <BusyButton Class="btn btn-outline-danger"
                                            IsBusy="_isDeleting"
                                            Disabled="@(_isSaving || _isDeleting)"
                                            BusyText="Deleting..."
                                            OnClick="DeleteAsync">
                                    <i class="fa-regular fa-trash me-2" aria-hidden="true"></i>
                                    Delete
                                </BusyButton>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-outline-primary"
                                    title="@BuildAiButtonTitle()"
                                    aria-label="@BuildAiButtonTitle()"
                                    @onclick="OpenAiAssist">
                                <i class="fa-regular fa-wand-magic-sparkles" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Close</button>
                            <BusyButton Class="btn btn-primary"
                                        IsBusy="_isSaving"
                                        Disabled="@(_isSaving || _isDeleting)"
                                        BusyText="Saving..."
                                        OnClick="SaveAsync">
                                <i class="fa-regular fa-floppy-disk me-2" aria-hidden="true"></i>
                                Save
                            </BusyButton>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</AppModal>

<StoryEntityAiAssistModal ThreadId="ThreadId"
                          IsOpen="_isAiAssistOpen"
                          EntityKind="StoryEntityKind.Item"
                          EntityId="_selectedItemId"
                          OnAccepted="HandleAiAcceptedAsync"
                          OnClose="CloseAiAssistAsync" />
<StoryFieldGuidanceModal IsOpen="_isGuidanceOpen"
                         EntityKind="StoryEntityKind.Item"
                         FieldKey="_selectedGuidanceFieldKey"
                         OnSaved="HandleGuidanceSavedAsync"
                         OnClose="CloseGuidanceAsync" />

@code {
    [Parameter]
    public Guid ThreadId { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public Guid? InitialItemId { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private bool _isLoading;
    private bool _isSaving;
    private bool _isDeleting;
    private bool _wasOpen;
    private Guid? _loadedThreadId;
    private Guid? _selectedItemId;
    private IReadOnlyList<StoryItemEditorView> _items = [];
    private IReadOnlyList<StoryCharacterEditorView> _characters = [];
    private IReadOnlyList<StoryLocationEditorView> _locations = [];
    private string _name = string.Empty;
    private string _summary = string.Empty;
    private string _details = string.Empty;
    private string _ownerCharacterIdText = string.Empty;
    private string _locationIdText = string.Empty;
    private bool _isPresentInScene;
    private bool _isAiAssistOpen;
    private bool _isGuidanceOpen;
    private StoryEntityFieldKey _selectedGuidanceFieldKey = StoryEntityFieldKey.Name;
    private IReadOnlyList<StoryEntityFieldGuidanceView> _fieldGuidance = [];
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _wasOpen = false;
            return;
        }

        if (_wasOpen && _loadedThreadId == ThreadId)
            return;

        _wasOpen = true;
        _loadedThreadId = ThreadId;
        await LoadAsync(InitialItemId);
    }

    private async Task LoadAsync(Guid? selectedItemId = null)
    {
        _isLoading = true;
        try
        {
            var itemTask = ChatStoryService.GetItemsAsync(ThreadId, CancellationToken.None);
            var characterTask = ChatStoryService.GetCharactersAsync(ThreadId, CancellationToken.None);
            var locationTask = ChatStoryService.GetLocationEditorsAsync(ThreadId, CancellationToken.None);
            var guidanceTask = StoryFieldGuidanceService.GetGuidanceAsync(StoryEntityKind.Item, CancellationToken.None);
            await Task.WhenAll(itemTask, characterTask, locationTask, guidanceTask);

            _items = itemTask.Result;
            _characters = characterTask.Result;
            _locations = locationTask.Result;
            _fieldGuidance = guidanceTask.Result;

            var targetItemId = selectedItemId
                ?? _selectedItemId
                ?? _items.FirstOrDefault()?.ItemId;
            if (targetItemId.HasValue)
                SelectItem(targetItemId.Value);
            else
                BeginCreate();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginCreate()
    {
        _errorMessage = null;
        _selectedItemId = null;
        _name = string.Empty;
        _summary = string.Empty;
        _details = string.Empty;
        _ownerCharacterIdText = string.Empty;
        _locationIdText = string.Empty;
        _isPresentInScene = false;
    }

    private void SelectItem(Guid itemId)
    {
        var item = _items.FirstOrDefault(x => x.ItemId == itemId);
        if (item is null)
        {
            BeginCreate();
            return;
        }

        _errorMessage = null;
        _selectedItemId = item.ItemId;
        _name = item.Name;
        _summary = item.Summary;
        _details = item.Details;
        _ownerCharacterIdText = item.OwnerCharacterId?.ToString() ?? string.Empty;
        _locationIdText = item.LocationId?.ToString() ?? string.Empty;
        _isPresentInScene = item.IsPresentInScene;
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        _isSaving = true;
        try
        {
            var savedItem = await ChatStoryService.UpsertItemAsync(
                new UpsertItem(
                    ThreadId,
                    _selectedItemId,
                    _name,
                    _summary,
                    _details,
                    ParseGuidOrNull(_ownerCharacterIdText),
                    ParseGuidOrNull(_locationIdText),
                    _isPresentInScene,
                    false),
                CancellationToken.None);

            await LoadAsync(savedItem.ItemId);
            await NotifyChangedAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving item {ItemName} failed for chat {ChatId}.", _name, ThreadId);
            _errorMessage = $"Saving item '{BuildDisplayName()}' failed.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!_selectedItemId.HasValue)
            return;

        var displayName = BuildDisplayName();
        _errorMessage = null;
        _isDeleting = true;
        try
        {
            await ChatStoryService.DeleteItemAsync(new DeleteItem(ThreadId, _selectedItemId.Value), CancellationToken.None);
            await LoadAsync();
            await NotifyChangedAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Deleting item {ItemId} failed for chat {ChatId}.", _selectedItemId.Value, ThreadId);
            _errorMessage = $"Deleting item '{displayName}' failed.";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task NotifyChangedAsync()
    {
        if (OnChanged.HasDelegate)
            await OnChanged.InvokeAsync();
    }

    private void OpenAiAssist() => _isAiAssistOpen = true;

    private void OpenGuidance(StoryEntityFieldKey fieldKey)
    {
        _selectedGuidanceFieldKey = fieldKey;
        _isGuidanceOpen = true;
    }

    private Task CloseAiAssistAsync()
    {
        _isAiAssistOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseGuidanceAsync()
    {
        _isGuidanceOpen = false;
        return Task.CompletedTask;
    }

    private async Task HandleAiAcceptedAsync(StoryEntityAcceptResult result)
    {
        _isAiAssistOpen = false;
        await LoadAsync(result.EntityId);
        await NotifyChangedAsync();
    }

    private async Task HandleGuidanceSavedAsync(StoryEntityFieldGuidanceView guidance)
    {
        _isGuidanceOpen = false;
        _fieldGuidance = await StoryFieldGuidanceService.GetGuidanceAsync(StoryEntityKind.Item, CancellationToken.None);
    }

    private Task CloseAsync() => OnClose.InvokeAsync();

    private bool IsCreatingItem => !_selectedItemId.HasValue;

    private string BuildCreateButtonTitle() => IsCreatingItem
        ? "Already creating a new item"
        : "Add item";

    private string BuildAiButtonTitle() => _selectedItemId.HasValue
        ? "Edit item with prompt"
        : "New item from prompt";

    private static Guid? ParseGuidOrNull(string? value) =>
        Guid.TryParse(value, out var id)
            ? id
            : null;

    private string BuildDisplayName() => string.IsNullOrWhiteSpace(_name) ? "Untitled Item" : _name.Trim();

    private RenderFragment RenderGuidanceSummary(StoryEntityFieldKey fieldKey) => builder =>
    {
        var guidance = _fieldGuidance.FirstOrDefault(x => x.FieldKey == fieldKey);
        if (guidance is null)
            return;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "small text-body-secondary mt-1");
        builder.AddContent(2, BuildGuidanceSummary(guidance.Guidance));
        builder.CloseElement();
    };

    private static string BuildGuidanceSummary(StoryFieldGuidance guidance) =>
        $"{FormatGuidanceFormat(guidance.Format)}, {FormatDetail(guidance.LevelOfDetail)}, {guidance.SuggestedLength.Minimum}-{guidance.SuggestedLength.Maximum} {FormatLengthMeasure(guidance.Format)}";

    private static string FormatGuidanceFormat(StoryFieldGuidanceFormat guidanceFormat) => guidanceFormat switch
    {
        StoryFieldGuidanceFormat.Words => "list of words",
        StoryFieldGuidanceFormat.Sentences => "sentences",
        StoryFieldGuidanceFormat.Paragraphs => "paragraphs",
        StoryFieldGuidanceFormat.BulletList => "bullet list",
        _ => guidanceFormat.ToString()
    };

    private static string FormatDetail(StoryFieldGuidanceDetailLevel detailLevel) => detailLevel switch
    {
        StoryFieldGuidanceDetailLevel.Simple => "simple",
        StoryFieldGuidanceDetailLevel.Medium => "medium detail",
        StoryFieldGuidanceDetailLevel.Detailed => "detailed",
        _ => detailLevel.ToString()
    };

    private static string FormatLengthMeasure(StoryFieldGuidanceFormat guidanceFormat) => guidanceFormat switch
    {
        StoryFieldGuidanceFormat.Words => "words",
        StoryFieldGuidanceFormat.Sentences => "sentences",
        StoryFieldGuidanceFormat.Paragraphs => "paragraphs",
        StoryFieldGuidanceFormat.BulletList => "items",
        _ => guidanceFormat.ToString().ToLowerInvariant()
    };
}
