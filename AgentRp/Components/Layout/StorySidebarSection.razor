            ? []
            : text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private static bool AreGenerationSettingsEqual(StoryGenerationSettingsView left, StoryGenerationSettingsView right) =>
        AreStageSettingsEqual(left.Planning, right.Planning)
        && AreStageSettingsEqual(left.Writing, right.Writing);

    private static bool AreStageSettingsEqual(StoryModelStageSettingsView left, StoryModelStageSettingsView right) =>
        AreDoublesEqual(left.Temperature, right.Temperature)
        && AreNullableDoublesEqual(left.TopP, right.TopP)
        && left.MaxOutputTokens == right.MaxOutputTokens
        && left.Seed == right.Seed
        && AreNullableDoublesEqual(left.FrequencyPenalty, right.FrequencyPenalty)
        && AreNullableDoublesEqual(left.PresencePenalty, right.PresencePenalty)
        && left.StopSequences.SequenceEqual(right.StopSequences, StringComparer.Ordinal);

    private static bool AreDoublesEqual(double left, double right) => Math.Abs(left - right) < 0.001;

    private static bool AreNullableDoublesEqual(double? left, double? right) =>
        (!left.HasValue && !right.HasValue)
        || (left.HasValue && right.HasValue && AreDoublesEqual(left.Value, right.Value));

    private static string BuildGenerationSettingsSummary(StoryGenerationSettingsView settings) =>
        $"{BuildStageSummary("Pln", settings.Planning)} / {BuildStageSummary("Wrt", settings.Writing)}";

    private static string BuildStageSummary(string label, StoryModelStageSettingsView settings)
    {
        var tokens = new List<string> { $"{label} T{FormatTemperature(settings.Temperature)}" };
        if (settings.TopP.HasValue)
            tokens.Add($"Tp{FormatOptional(settings.TopP.Value)}");

        if (settings.MaxOutputTokens.HasValue)
            tokens.Add($"Max{settings.MaxOutputTokens.Value}");

        if (settings.Seed.HasValue)
            tokens.Add($"Sd{settings.Seed.Value}");

        return string.Join(' ', tokens);
    }

