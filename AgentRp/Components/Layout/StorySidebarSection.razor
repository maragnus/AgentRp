@implements IDisposable
@inject IChatWorkspaceService ChatWorkspaceService
@inject IChatStoryService ChatStoryService
@inject IStorySceneChatService StorySceneChatService
@inject IThreadAgentService ThreadAgentService
@inject IStoryGenerationSettingsService StoryGenerationSettingsService
@inject IStoryScenePromptLibraryService StoryScenePromptLibraryService
@inject IActivityNotifier ActivityNotifier
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILogger<StorySidebarSection> Logger

<div class="card border-0 bg-body-tertiary shadow-sm mb-3">
    <div class="card-body d-flex flex-column gap-3 p-3">
        <div class="d-flex align-items-start justify-content-between gap-3">
            <div>
                <div class="small text-uppercase text-body-secondary">Story</div>
            </div>

            <div class="d-flex align-items-center justify-content-end gap-2 ms-auto">
                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        title="Image gallery"
                        aria-label="Image gallery"
                        @onclick="OpenImageGalleryModal">
                    <i class="fa-regular fa-image" aria-hidden="true"></i>
                </button>

                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        title="Image optimization"
                        aria-label="Image optimization"
                        @onclick="OpenImageOptimizationModal">
                    <i class="fa-regular fa-wand-magic-sparkles" aria-hidden="true"></i>
                </button>

                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        title="Prompt library"
                        aria-label="Prompt library"
                        @onclick="OpenPromptLibraryModal">
                    <i class="fa-regular fa-pen-nib" aria-hidden="true"></i>
                </button>

                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        title="Story Context"
                        aria-label="Story Context"
                        @onclick="OpenHistoryModal">
                    <i class="fa-regular fa-timeline" aria-hidden="true"></i>
                </button>
            </div>
        </div>

        <InlineAlert Message="@_errorMessage" />

        @if (_isLoading)
        {
            <div class="d-flex align-items-center gap-2 small text-body-secondary">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>Loading story details...</span>
            </div>
        }
        else if (!_threadId.HasValue || _story is null)
        {
            <div class="small text-body-secondary">Story details appear here once a chat is available.</div>
        }
        else
        {
            <div>
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div class="small text-uppercase text-body-secondary">AI Model</div>
                    <div class="d-flex align-items-center gap-1 flex-shrink-0">
                        @if (_story.AvailableAgents.Count > 0)
                        {
                            <div class="dropdown">
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm dropdown-toggle"
                                        title="Switch model"
                                        aria-label="Switch model"
                                        aria-expanded="@_isModelSwitcherOpen"
                                        @onclick="ToggleModelSwitcher">
                                    <i class="fa-regular fa-shuffle" aria-hidden="true"></i>
                                </button>
                                @if (_isModelSwitcherOpen)
                                {
                                    <div class="dropdown-menu dropdown-menu-end show app-model-switcher-menu">
                                        @foreach (var group in AvailableAgentGroups)
                                        {
                                            <div @key="group.ProviderId" class="dropdown-header text-truncate" title="@group.ProviderName">@group.ProviderName</div>
                                            @foreach (var agent in group.Agents)
                                            {
                                                var isSelected = _story.SelectedModelId == agent.ModelId;
                                                var isSwitchingAgent = _switchingAgentNames.Contains(agent.Name);

                                                <button type="button"
                                                        @key="agent.ModelId"
                                                        class="dropdown-item d-flex align-items-center justify-content-between gap-2 @(isSelected ? "active" : string.Empty)"
                                                        disabled="@(isSwitchingAgent || isSelected)"
                                                        title="@agent.Name"
                                                        @onclick="() => SelectAgentAsync(agent.ModelId, agent.Name)">
                                                    <span class="text-truncate">@agent.Name</span>
                                                    @if (isSelected)
                                                    {
                                                        <i class="fa-regular fa-check flex-shrink-0" aria-hidden="true"></i>
                                                    }
                                                </button>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Edit selected model settings"
                                    aria-label="Edit selected model settings"
                                    @onclick="OpenGenerationSettingsModal">
                                <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                            </button>
                        }
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm"
                                title="Manage AI providers"
                                aria-label="Manage AI providers"
                                @onclick="OpenProviderEditor">
                            <i class="fa-regular fa-server" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                @if (_story.AvailableAgents.Count == 0)
                {
                    <div class="alert alert-light border mb-0">
                        <div class="fw-semibold mb-1">Connect an AI provider</div>
                        <div class="small text-body-secondary mb-2">Add a platform API key, discover models, and enable one model to get started.</div>
                        <button type="button" class="btn btn-primary btn-sm" @onclick="OpenProviderEditor">
                            <i class="fa-regular fa-plug me-2" aria-hidden="true"></i>
                            Set Up AI
                        </button>
                    </div>
                }
                else
                {
                    <div class="min-w-0 overflow-hidden">
                        <div class="fw-semibold text-truncate" title="@(_story.SelectedAgentName ?? "No model selected")">@(_story.SelectedAgentName ?? "No model selected")</div>
                        <div class="small text-body-secondary text-truncate" title="@SelectedProviderSummary">@SelectedProviderSummary</div>
                    </div>

                    @if (_generationSettings is not null)
                    {
                        <div class="small text-body-secondary text-truncate mt-2" title="@BuildGenerationSettingsSummary(_generationSettings)">
                            @BuildGenerationSettingsSummary(_generationSettings)
                        </div>
                    }

                    @if (ShouldShowSelectedProviderMetrics)
                    {
                        var provider = _story.SelectedProvider!;
                        <div class="pt-2 mt-2">
                            @if (!string.IsNullOrWhiteSpace(provider.ErrorMessage))
                            {
                                <div class="small text-danger mb-1">@provider.ErrorMessage</div>
                            }
                            @if (HasProviderTokenUsage(provider.TokenUsage))
                            {
                                <div class="d-flex align-items-center justify-content-between gap-2 small text-body-secondary">
                                    <span class="text-truncate">Chat Tokens</span>
                                    <span class="text-truncate">@BuildProviderTokenSummary(provider.TokenUsage)</span>
                                </div>
                            }
                            @foreach (var metric in provider.Metrics.Take(3))
                            {
                                <div @key="metric.MetricKind" class="d-flex align-items-center justify-content-between gap-2 small text-body-secondary" title="@metric.Detail">
                                    <span class="text-truncate">@metric.Label</span>
                                    <span class="text-truncate">@metric.Value</span>
                                </div>
                            }
                        </div>
                    }

                    <ManagedEndpointStatusPanel @key="_story.SelectedAgentName"
                                                SelectedAgentName="@_story.SelectedAgentName"
                                                IsManagedEndpointAgent="@IsSelectedManagedEndpointAgent"
                                                InitialEndpoint="@SelectedManagedEndpoint"
                                                InitialErrorMessage="@SelectedManagedEndpointErrorMessage" />
@*
                    <div class="row row-cols-3 g-2">
                        @foreach (var agent in _story.AvailableAgents)
                        {
                            var agentButtonClass = string.Equals(_story.SelectedAgentName, agent.Name, StringComparison.Ordinal)
                                ? "btn btn-primary btn-sm w-100 text-truncate"
                                : "btn btn-outline-primary btn-sm w-100 text-truncate";
                            var isSwitchingAgent = _switchingAgentNames.Contains(agent.Name);

                            <div class="col">
                                <BusyButton Class="@agentButtonClass"
                                            IsBusy="@isSwitchingAgent"
                                            Disabled="@(isSwitchingAgent || string.Equals(_story.SelectedAgentName, agent.Name, StringComparison.Ordinal))"
                                            BusyText=""
                                            ShowBusyText="false"
                                            title="@(string.Equals(_story.SelectedAgentName, agent.Name, StringComparison.Ordinal) ? $"{agent.Name} is already selected" : $"Use {agent.Name} for AI actions")"
                                            aria-label="@(string.Equals(_story.SelectedAgentName, agent.Name, StringComparison.Ordinal) ? $"{agent.Name} is already selected" : $"Use {agent.Name} for AI actions")"
                                            OnClick="() => SelectAgentAsync(agent.Name)">
                                    @agent.Name
                                </BusyButton>
                            </div>
                        }
                    </div>

                    @if (SelectedManagedEndpoint is not null || ShouldShowManagedEndpointError)
                    {
                        <div class="border-top pt-2 mt-2">
                            @if (ShouldShowManagedEndpointError)
                            {
                                <div class="small text-body-secondary">@_story.ManagedAgentEndpointsErrorMessage</div>
                            }
                            else
                            {
                                var endpoint = SelectedManagedEndpoint!;
                                var isManagingEndpoint = IsManagingEndpoint(endpoint.AgentName);

                                <div class="d-flex align-items-center justify-content-between gap-2">
                                    <div class="d-flex align-items-center gap-2 overflow-hidden">
                                        <span class="@BuildManagedEndpointStatusIconClass(endpoint.State)"
                                              title="@FormatManagedEndpointState(endpoint.State)"
                                              aria-label="@FormatManagedEndpointState(endpoint.State)">
                                            <i class="@BuildManagedEndpointStatusIcon(endpoint.State)" aria-hidden="true"></i>
                                        </span>

                                        @if (endpoint.IsLinked)
                                        {
                                            @if (endpoint.StatusUpdatedUtc.HasValue)
                                            {
                                                <span class="small text-body-secondary text-truncate">@FormatManagedEndpointAge(endpoint)</span>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(endpoint.StatusMessage))
                                            {
                                                <span class="small text-body-secondary text-truncate">@endpoint.StatusMessage</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="small text-body-secondary text-truncate">@GetManagedEndpointUnlinkedText(endpoint)</span>
                                        }
                                    </div>

                                    @if (endpoint.IsLinked)
                                    {
                                        <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                            @if (endpoint.CanStart)
                                            {
                                                <BusyButton Class="btn btn-outline-success btn-sm"
                                                            IsBusy="@IsManagingEndpointAction(endpoint.AgentName, ManagedAgentAction.Start)"
                                                            Disabled="@isManagingEndpoint"
                                                            BusyText=""
                                                            ShowBusyText="false"
                                                            title="@($"Start {endpoint.AgentName}")"
                                                            aria-label="@($"Start {endpoint.AgentName}")"
                                                            OnClick="() => ManageEndpointAsync(endpoint, ManagedAgentAction.Start)">
                                                    <i class="fa-regular fa-play" aria-hidden="true"></i>
                                                </BusyButton>
                                            }

                                            @if (endpoint.CanPause)
                                            {
                                                <BusyButton Class="btn btn-outline-secondary btn-sm"
                                                            IsBusy="@IsManagingEndpointAction(endpoint.AgentName, ManagedAgentAction.Pause)"
                                                            Disabled="@isManagingEndpoint"
                                                            BusyText=""
                                                            ShowBusyText="false"
                                                            title="@($"Pause {endpoint.AgentName}")"
                                                            aria-label="@($"Pause {endpoint.AgentName}")"
                                                            OnClick="() => ManageEndpointAsync(endpoint, ManagedAgentAction.Pause)">
                                                    <i class="fa-regular fa-pause" aria-hidden="true"></i>
                                                </BusyButton>
                                            }

                                            @if (endpoint.CanScaleToZero)
                                            {
                                                <BusyButton Class="btn btn-outline-danger btn-sm"
                                                            IsBusy="@IsManagingEndpointAction(endpoint.AgentName, ManagedAgentAction.ScaleToZero)"
                                                            Disabled="@isManagingEndpoint"
                                                            BusyText=""
                                                            ShowBusyText="false"
                                                            title="@($"Scale {endpoint.AgentName} to zero")"
                                                            aria-label="@($"Scale {endpoint.AgentName} to zero")"
                                                            OnClick="() => ManageEndpointAsync(endpoint, ManagedAgentAction.ScaleToZero)">
                                                    <i class="fa-regular fa-power-off" aria-hidden="true"></i>
                                                </BusyButton>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (_generationSettings is not null)
                    {
                        <div class="border-top pt-2 mt-2">
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div>
                                    <div class="small text-uppercase text-body-secondary">Model Settings</div>
                                    <div class="small text-body-secondary text-truncate" title="@BuildGenerationSettingsSummary(_generationSettings)">
                                        @BuildGenerationSettingsSummary(_generationSettings)
                                    </div>
                                </div>
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        title="Edit model settings"
                                        aria-label="Edit model settings"
                                        @onclick="OpenGenerationSettingsModal">
                                    <i class="fa-regular fa-sliders" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    }
*@
                }
            </div>

            <div class="border-top pt-2 mt-2">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                    <div class="small text-uppercase text-body-secondary">Current Location</div>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            title="Manage locations"
                            aria-label="Manage locations"
                            @onclick="OpenLocationsModal">
                        <i class="fa-regular fa-location-dot" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="list-group list-group-flush">
                    <div class="list-group-item bg-transparent px-0 py-2">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="d-flex align-items-center gap-2">
                                    <StoryAvatar Name="@(_story.CurrentLocationName ?? "No current location")"
                                                 ImageUrl="@_story.CurrentLocationPrimaryImageUrl"
                                                 Crop="@_story.CurrentLocationPrimaryImageCrop"
                                                 Class="app-story-avatar-sm flex-shrink-0" />
                                    <div class="fw-semibold text-truncate">@(_story.CurrentLocationName ?? "No current location")</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        title="Edit location"
                                        aria-label="Edit location"
                                        @onclick="() => OpenLocationsModal(_story.CurrentLocationId)">
                                    <i class="fa-regular fa-pen" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="border-top pt-3">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div class="small text-uppercase text-body-secondary">Characters</div>
                    <button type="button"
                            class="btn btn-outline-primary btn-sm"
                            title="Manage characters"
                            aria-label="Manage characters"
                            @onclick="OpenCharacterModal">
                        <i class="fa-regular fa-pen-to-square" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="list-group list-group-flush">
                    @foreach (var speaker in _story.Speakers)
                    {
                        var speakerRowClass = speaker.IsSelected
                            ? "list-group-item bg-primary-subtle border-primary-subtle px-0 py-2"
                            : "list-group-item bg-transparent px-0 py-2";
                        var speakerButtonClass = speaker.IsSelected ? "btn btn-primary btn-sm" : "btn btn-outline-primary btn-sm";
                        var speakerKey = GetSpeakerKey(speaker.CharacterId);

                        <div @key="speakerKey" class="@speakerRowClass">
                            <div class="d-flex align-items-start justify-content-between gap-2">
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!speaker.IsNarrator)
                                        {
                                            <StoryAvatar Name="@speaker.Name"
                                                         ImageUrl="@speaker.PrimaryImageUrl"
                                                         Crop="@speaker.PrimaryImageCrop"
                                                         Class="app-story-avatar-sm flex-shrink-0" />
                                        }
                                        <div class="fw-semibold text-truncate">@speaker.Name</div>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                    <BusyButton Class="@speakerButtonClass"
                                                ShowBusyText="false"
                                                IsBusy="@_switchingSpeakerKeys.Contains(speakerKey)"
                                                Disabled="@(_switchingSpeakerKeys.Contains(speakerKey) || speaker.IsSelected)"
                                                BusyText=""
                                                title="@(speaker.IsSelected ? $"{speaker.Name} is already the active speaker" : $"Speak as {speaker.Name}")"
                                                aria-label="@(speaker.IsSelected ? $"{speaker.Name} is already the active speaker" : $"Speak as {speaker.Name}")"
                                                OnClick="() => SelectSpeakerAsync(speaker)">
                                        <i class="fa-regular fa-comments" aria-hidden="true"></i>
                                    </BusyButton>

                                    @if (!speaker.IsNarrator)
                                    {
                                        var character = _story.Characters.First(x => x.CharacterId == speaker.CharacterId!.Value);

                                        <BusyButton Class="@($"btn btn-sm {(character.IsPresentInScene ? "btn-outline-success" : "btn-outline-secondary")}")"
                                                    ShowBusyText="false"
                                                    IsBusy="@_togglingCharacterIds.Contains(character.CharacterId)"
                                                    Disabled="@_togglingCharacterIds.Contains(character.CharacterId)"
                                                    BusyText=""
                                                    title="@(character.IsPresentInScene ? "Remove from scene" : "Add to scene")"
                                                    aria-label="@(character.IsPresentInScene ? $"Remove {character.Name} from scene" : $"Add {character.Name} to scene")"
                                                    OnClick="() => ToggleCharacterScenePresenceAsync(character)">
                                            <i class="fa-regular @(character.IsPresentInScene ? "fa-eye" : "fa-eye-slash")" aria-hidden="true"></i>
                                        </BusyButton>
                                        <button type="button"
                                                class="btn btn-outline-secondary btn-sm"
                                                title="Edit character"
                                                aria-label="Edit character"
                                                @onclick="() => OpenCharacterModal(character.CharacterId)">
                                            <i class="fa-regular fa-pen" aria-hidden="true"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (_story.Characters.Count == 0)
                    {
                        <div class="small text-body-secondary pt-2">No characters yet. Narrator is available as the active speaker.</div>
                    }
                </div>
            </div>

            <div class="border-top pt-3">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div class="small text-uppercase text-body-secondary">Scene Items</div>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            title="Items"
                            aria-label="Items"
                            @onclick="OpenItemsModal">
                        <i class="fa-regular fa-box-archive" aria-hidden="true"></i>
                    </button>
                </div>
                @if (_story.SceneItems.Count == 0)
                {
                    <div class="small text-body-secondary">No major items are currently in the scene.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var item in _story.SceneItems)
                        {
                            <div @key="item.ItemId" class="list-group-item bg-transparent px-0 py-2">
                                <div class="d-flex align-items-start justify-content-between gap-2">
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex align-items-center gap-2">
                                            <StoryAvatar Name="@item.Name"
                                                         ImageUrl="@item.PrimaryImageUrl"
                                                         Crop="@item.PrimaryImageCrop"
                                                         Class="app-story-avatar-sm flex-shrink-0" />
                                            <div class="fw-semibold text-truncate">@item.Name</div>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                        <BusyButton Class="btn btn-outline-success btn-sm"
                                                    ShowBusyText="false"
                                                    IsBusy="@_togglingItemIds.Contains(item.ItemId)"
                                                    Disabled="@_togglingItemIds.Contains(item.ItemId)"
                                                    BusyText=""
                                                    title="Remove from scene"
                                                    aria-label="@($"Remove {item.Name} from scene")"
                                                    OnClick="() => ToggleItemScenePresenceAsync(item)">
                                            <i class="fa-regular fa-eye" aria-hidden="true"></i>
                                        </BusyButton>
                                        <button type="button"
                                                class="btn btn-outline-secondary btn-sm"
                                                title="Edit item"
                                                aria-label="Edit item"
                                                @onclick="() => OpenItemsModal(item.ItemId)">
                                            <i class="fa-regular fa-pen" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (_threadId.HasValue)
{
    <StoryCharacterModal ThreadId="_threadId.Value"
                         IsOpen="_isCharacterModalOpen"
                         InitialCharacterId="_selectedCharacterIdForModal"
                         StartInCreateMode="_startCharacterModalInCreateMode"
                         OnClose="CloseCharacterModal"
                         OnChanged="HandleStoryChangedAsync" />
    <StoryLocationsModal ThreadId="_threadId.Value"
                         IsOpen="_isLocationsModalOpen"
                         InitialLocationId="_selectedLocationIdForModal"
                         OnClose="CloseLocationsModal"
                         OnChanged="HandleStoryChangedAsync" />
    <StoryItemsModal ThreadId="_threadId.Value"
                     IsOpen="_isItemsModalOpen"
                     InitialItemId="_selectedItemIdForModal"
                     OnClose="CloseItemsModal"
                     OnChanged="HandleStoryChangedAsync" />
    <StoryHistoryModal ThreadId="_threadId.Value"
                       IsOpen="_isHistoryModalOpen"
                       OnClose="CloseHistoryModal"
                       OnChanged="HandleStoryChangedAsync" />
    <StoryImageCatalogModal ThreadId="_threadId.Value"
                            IsOpen="_isImageGalleryModalOpen"
                            GalleryMode="true"
                            OnClose="CloseImageGalleryModal" />
}

<StoryImageOptimizationModal IsOpen="_isImageOptimizationModalOpen"
                             OnClose="CloseImageOptimizationModal"
                             OnChanged="HandleStoryChangedAsync" />

<AiProviderModelEditorModal IsOpen="_isProviderEditorOpen"
                            OnClose="CloseProviderEditor"
                            OnChanged="HandleStoryChangedAsync" />

<AppModal IsOpen="@_isGenerationSettingsModalOpen"
          Title="Model Settings"
          DialogClass="modal-lg modal-dialog-scrollable modal-fullscreen-sm-down"
          OnClose="CloseGenerationSettingsModal">
    <ChildContent>
        <div class="d-flex flex-column gap-3">
            <InlineAlert Message="@_generationSettingsErrorMessage" />

            <div class="small text-body-secondary">
                Lower temperature is steadier. Leave optional fields blank to use the model defaults. Import and export act on the active tab only.
            </div>

            <ul class="nav nav-tabs">
                <li class="nav-item">
                    <button type="button"
                            class="@BuildGenerationSettingsTabClass(StoryGenerationStage.Planning)"
                            disabled="@IsGenerationSettingsBusy"
                            @onclick="() => SelectGenerationSettingsStage(StoryGenerationStage.Planning)">
                        Planning
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button"
                            class="@BuildGenerationSettingsTabClass(StoryGenerationStage.Writing)"
                            disabled="@IsGenerationSettingsBusy"
                            @onclick="() => SelectGenerationSettingsStage(StoryGenerationStage.Writing)">
                        Writing
                    </button>
                </li>
            </ul>

            <div class="d-flex flex-wrap align-items-center gap-2">
                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        disabled="@IsGenerationSettingsBusy"
                        @onclick="SyncActiveGenerationSettingsDraft">
                    <i class="fa-regular fa-arrows-rotate me-2" aria-hidden="true"></i>
                    @BuildSyncButtonText()
                </button>

                <BusyButton Class="btn btn-outline-secondary btn-sm"
                            IsBusy="@_isExportingGenerationSettings"
                            Disabled="@(_generationSettings is null || _isSavingGenerationSettings || _isImportingGenerationSettings)"
                            BusyText="Exporting..."
                            OnClick="ExportGenerationSettingsAsync">
                    <i class="fa-regular fa-arrow-up-from-bracket me-2" aria-hidden="true"></i>
                    Export JSON
                </BusyButton>

                <label class="btn btn-outline-secondary btn-sm mb-0 @(IsGenerationSettingsBusy ? "disabled" : string.Empty)"
                       for="@_generationSettingsImportInputId"
                       aria-disabled="@IsGenerationSettingsBusy">
                    <i class="fa-regular fa-arrow-down-to-bracket me-2" aria-hidden="true"></i>
                    Import JSON
                </label>
                <InputFile @key="_generationSettingsImportInputKey"
                           id="@_generationSettingsImportInputId"
                           class="d-none"
                           accept=".json"
                           disabled="@IsGenerationSettingsBusy"
                           OnChange="HandleGenerationSettingsImportAsync" />

                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        disabled="@IsGenerationSettingsBusy"
                        @onclick="ToggleGenerationSettingsCopy">
                    <i class="fa-regular fa-copy me-2" aria-hidden="true"></i>
                    Copy To
                </button>
            </div>

            @if (_isGenerationSettingsCopyOpen && _story is not null)
            {
                <div class="list-group">
                    @foreach (var model in _story.AvailableAgents.Where(x => x.ModelId != _generationSettingsModelId))
                    {
                        <div @key="model.ModelId" class="list-group-item">
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="min-w-0">
                                    <div class="fw-semibold text-truncate">@model.Name</div>
                                    <div class="small text-body-secondary">@model.ProviderName</div>
                                </div>
                                <select class="form-select form-select-sm w-auto" @bind="_generationSettingsCopyTargets[model.ModelId]">
                                    <option value="@StoryGenerationSettingsCopySlot.Planning">Planning</option>
                                    <option value="@StoryGenerationSettingsCopySlot.Writing">Writing</option>
                                    <option value="@StoryGenerationSettingsCopySlot.Both">Both</option>
                                </select>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (_isImportingGenerationSettings)
            {
                <div class="d-flex align-items-center gap-2 small text-body-secondary">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span>Reading @DescribeGenerationStage(_activeGenerationSettingsStage) settings...</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_generationSettingsImportFileName))
            {
                <div class="small text-body-secondary">
                    Import file: @_generationSettingsImportFileName
                </div>
            }

            <div class="row g-3">
                <div class="col-12">
                    <label for="@_activeTemperatureInputId" class="form-label d-flex align-items-center justify-content-between">
                        <span>Temperature</span>
                        <span class="text-body-secondary">@FormatTemperature(ActiveTemperature)</span>
                    </label>
                    <input id="@_activeTemperatureInputId"
                           class="form-range"
                           type="range"
                           min="0"
                           max="2"
                           step="0.1"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActiveTemperature"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-6">
                    <label for="@_activeTopPInputId" class="form-label">Top P</label>
                    <input id="@_activeTopPInputId"
                           class="form-control"
                           type="number"
                           min="0"
                           max="1"
                           step="0.01"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActiveTopP"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-6">
                    <label for="@_activeMaxOutputTokensInputId" class="form-label">Max Output Tokens</label>
                    <input id="@_activeMaxOutputTokensInputId"
                           class="form-control"
                           type="number"
                           min="1"
                           step="1"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActiveMaxOutputTokens"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-6">
                    <label for="@_activeSeedInputId" class="form-label">Seed</label>
                    <input id="@_activeSeedInputId"
                           class="form-control"
                           type="number"
                           min="0"
                           step="1"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActiveSeed"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-6">
                    <label for="@_activeFrequencyPenaltyInputId" class="form-label">Frequency Penalty</label>
                    <input id="@_activeFrequencyPenaltyInputId"
                           class="form-control"
                           type="number"
                           min="-2"
                           max="2"
                           step="0.01"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActiveFrequencyPenalty"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-6">
                    <label for="@_activePresencePenaltyInputId" class="form-label">Presence Penalty</label>
                    <input id="@_activePresencePenaltyInputId"
                           class="form-control"
                           type="number"
                           min="-2"
                           max="2"
                           step="0.01"
                           disabled="@IsGenerationSettingsBusy"
                           @bind="ActivePresencePenalty"
                           @bind:event="oninput" />
                </div>

                <div class="col-12">
                    <label for="@_activeStopSequencesInputId" class="form-label">Stop Sequences</label>
                    <textarea id="@_activeStopSequencesInputId"
                              class="form-control"
                              rows="4"
                              disabled="@IsGenerationSettingsBusy"
                              @bind="ActiveStopSequencesText"
                              @bind:event="oninput"></textarea>
                    <div class="small text-body-secondary mt-2">Enter one stop sequence per line.</div>
                </div>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button type="button"
                class="btn btn-outline-secondary"
                disabled="@IsGenerationSettingsBusy"
                @onclick="CloseGenerationSettingsModal">
            Cancel
        </button>
        @if (_isGenerationSettingsCopyOpen)
        {
            <BusyButton Class="btn btn-outline-primary"
                        IsBusy="@_isCopyingGenerationSettings"
                        Disabled="@IsGenerationSettingsBusy"
                        BusyText="Copying..."
                        OnClick="CopyGenerationSettingsAsync">
                Copy
            </BusyButton>
        }
        <BusyButton Class="btn btn-primary"
                    IsBusy="@_isSavingGenerationSettings"
                    Disabled="@(!CanSaveGenerationSettings)"
                    BusyText="Saving..."
                    OnClick="SaveGenerationSettingsAsync">
            <i class="fa-regular fa-floppy-disk me-2" aria-hidden="true"></i>
            Save
        </BusyButton>
    </FooterContent>
</AppModal>

<AppModal IsOpen="@_isPromptLibraryModalOpen"
          Title="Prompt Library"
          DialogClass="modal-xl modal-dialog-scrollable modal-fullscreen-sm-down"
          OnClose="ClosePromptLibraryModal">
    <ChildContent>
        <div class="d-flex flex-column gap-3">
            <InlineAlert Message="@_promptLibraryErrorMessage" />

            @if (_promptLibraryDraft is null || _promptLibraryDefaults is null)
            {
                <div class="d-flex align-items-center gap-2 small text-body-secondary">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span>Loading prompt library...</span>
                </div>
            }
            else
            {
                <ul class="nav nav-tabs">
                    @foreach (var stage in PromptLibraryStages)
                    {
                        <li @key="stage" class="nav-item">
                            <button type="button"
                                    class="@BuildPromptLibraryStageTabClass(stage)"
                                    disabled="@IsPromptLibraryBusy"
                                    @onclick="() => SelectPromptLibraryStage(stage)">
                                @DescribePromptStage(stage)
                            </button>
                        </li>
                    }
                </ul>

                <div class="row g-3">
                    <div class="col-12 col-xl-8">
                        <div class="d-flex flex-column gap-3">
                            @RenderPromptTextArea("System Prompt", ActivePromptStageDraft.SystemPromptInputId, ActivePromptStageDraft.SystemPrompt, value => ActivePromptStageDraft.SystemPrompt = value, () => ResetActivePromptSystemPrompt(), IsActiveSystemPromptDefault)
                            @RenderPromptTextArea("User Prompt Template", ActivePromptStageDraft.UserPromptInputId, ActivePromptStageDraft.UserPromptTemplate, value => ActivePromptStageDraft.UserPromptTemplate = value, () => ResetActivePromptUserPrompt(), IsActiveUserPromptDefault)

                            @if (_activePromptLibraryStage == StoryScenePromptStage.Planning || _activePromptLibraryStage == StoryScenePromptStage.Prose)
                            {
                                <div class="border-top pt-3">
                                    <div class="fw-semibold mb-2">Turn Shapes</div>
                                    <div class="row g-3">
                                        @foreach (var shape in PromptTurnShapes)
                                        {
                                            var shapeText = GetActiveTurnShapeTemplate(shape);
                                            var shapeInputId = GetActiveTurnShapeInputId(shape);
                                            var isDefault = IsActiveTurnShapeDefault(shape);

                                            <div @key="shape" class="col-12">
                                                <label for="@shapeInputId" class="form-label d-flex align-items-center justify-content-between gap-2">
                                                    <span>@DescribeTurnShape(shape)</span>
                                                    <button type="button"
                                                            class="btn btn-outline-secondary btn-sm"
                                                            disabled="@(IsPromptLibraryBusy || isDefault)"
                                                            title="@($"Reset {DescribeTurnShape(shape)} to default")"
                                                            aria-label="@($"Reset {DescribeTurnShape(shape)} to default")"
                                                            @onclick="() => ResetActiveTurnShape(shape)">
                                                        <i class="fa-regular fa-rotate-left" aria-hidden="true"></i>
                                                    </button>
                                                </label>
                                                <textarea id="@shapeInputId"
                                                          class="form-control font-monospace"
                                                          rows="@(_activePromptLibraryStage == StoryScenePromptStage.Planning ? 2 : 7)"
                                                          disabled="@IsPromptLibraryBusy"
                                                          value="@shapeText"
                                                          @oninput="args => SetActiveTurnShapeTemplate(shape, args.Value?.ToString() ?? string.Empty)"></textarea>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-12 col-xl-4">
                        <div class="border rounded p-3">
                            <div class="fw-semibold mb-2">Placeholders</div>
                            <div class="d-flex flex-column gap-2 small">
                                @foreach (var placeholder in ActivePromptPlaceholders)
                                {
                                    <div @key="placeholder.Token">
                                        <div class="d-flex align-items-center justify-content-between gap-2">
                                            <div class="font-monospace text-break">@placeholder.Token</div>
                                            <button type="button"
                                                    class="btn btn-outline-secondary btn-sm flex-shrink-0"
                                                    title="@($"Copy {placeholder.Token}")"
                                                    aria-label="@($"Copy {placeholder.Token}")"
                                                    @onclick="() => CopyPromptPlaceholderAsync(placeholder.Token)">
                                                <i class="fa-regular @(string.Equals(_copiedPromptPlaceholderToken, placeholder.Token, StringComparison.Ordinal) ? "fa-check" : "fa-copy")" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                        <div class="text-body-secondary">@placeholder.Description</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </ChildContent>
    <FooterContent>
        <button type="button"
                class="btn btn-outline-secondary"
                disabled="@IsPromptLibraryBusy"
                @onclick="ClosePromptLibraryModal">
            Cancel
        </button>
        <BusyButton Class="btn btn-primary"
                    IsBusy="@_isSavingPromptLibrary"
                    Disabled="@(!CanSavePromptLibrary)"
                    BusyText="Saving..."
                    OnClick="SavePromptLibraryAsync">
            <i class="fa-regular fa-floppy-disk me-2" aria-hidden="true"></i>
            Save
        </BusyButton>
    </FooterContent>
</AppModal>

@code {
    private IDisposable? _storySubscription;
    private IDisposable? _chatSubscription;
    private readonly string _generationSettingsImportInputId = $"story-generation-settings-import-{Guid.NewGuid():N}";
    private readonly string _activeTemperatureInputId = $"story-model-temperature-{Guid.NewGuid():N}";
    private readonly string _activeTopPInputId = $"story-model-top-p-{Guid.NewGuid():N}";
    private readonly string _activeMaxOutputTokensInputId = $"story-model-max-output-{Guid.NewGuid():N}";
    private readonly string _activeSeedInputId = $"story-model-seed-{Guid.NewGuid():N}";
    private readonly string _activeFrequencyPenaltyInputId = $"story-model-frequency-penalty-{Guid.NewGuid():N}";
    private readonly string _activePresencePenaltyInputId = $"story-model-presence-penalty-{Guid.NewGuid():N}";
    private readonly string _activeStopSequencesInputId = $"story-model-stop-sequences-{Guid.NewGuid():N}";
    private static readonly IReadOnlyList<StoryScenePromptStage> PromptLibraryStages =
    [
        StoryScenePromptStage.Appearance,
        StoryScenePromptStage.Selection,
        StoryScenePromptStage.Planning,
        StoryScenePromptStage.Prose
    ];
    private static readonly IReadOnlyList<StoryTurnShape> PromptTurnShapes =
    [
        StoryTurnShape.Compact,
        StoryTurnShape.Brief,
        StoryTurnShape.Monologue,
        StoryTurnShape.Extended,
        StoryTurnShape.Silent,
        StoryTurnShape.SilentMonologue
    ];
    private bool _isLoading;
    private Guid? _threadId;
    private ChatStorySidebarView? _story;
    private StoryGenerationSettingsView? _generationSettings;
    private bool _isCharacterModalOpen;
    private bool _isLocationsModalOpen;
    private bool _isItemsModalOpen;
    private bool _isHistoryModalOpen;
    private bool _isImageGalleryModalOpen;
    private bool _isImageOptimizationModalOpen;
    private bool _isGenerationSettingsModalOpen;
    private bool _isPromptLibraryModalOpen;
    private bool _isProviderEditorOpen;
    private bool _isModelSwitcherOpen;
    private bool _isSavingGenerationSettings;
    private bool _isExportingGenerationSettings;
    private bool _isImportingGenerationSettings;
    private bool _isCopyingGenerationSettings;
    private bool _isGenerationSettingsCopyOpen;
    private bool _isSavingPromptLibrary;
    private int _generationSettingsImportInputKey;
    private string? _generationSettingsImportFileName;
    private StoryGenerationStage _activeGenerationSettingsStage = StoryGenerationStage.Planning;
    private StoryModelStageSettingsDraft _planningGenerationSettingsDraft = new();
    private StoryModelStageSettingsDraft _writingGenerationSettingsDraft = new();
    private Guid? _selectedCharacterIdForModal;
    private Guid? _selectedLocationIdForModal;
    private Guid? _selectedItemIdForModal;
    private bool _startCharacterModalInCreateMode;
    private string? _errorMessage;
    private string? _generationSettingsErrorMessage;
    private string? _promptLibraryErrorMessage;
    private Guid? _generationSettingsModelId;
    private StoryScenePromptLibraryView? _promptLibrary;
    private StoryScenePromptLibraryView? _promptLibraryDefaults;
    private PromptLibraryDraft? _promptLibraryDraft;
    private StoryScenePromptStage _activePromptLibraryStage = StoryScenePromptStage.Appearance;
    private string? _copiedPromptPlaceholderToken;
    private CancellationTokenSource? _promptPlaceholderCopyFeedbackCancellation;
    private HashSet<Guid> _togglingCharacterIds = [];
    private HashSet<Guid> _togglingItemIds = [];
    private HashSet<string> _switchingSpeakerKeys = [];
    private HashSet<string> _switchingAgentNames = [];
    private Dictionary<Guid, StoryGenerationSettingsCopySlot> _generationSettingsCopyTargets = [];

    protected override async Task OnInitializedAsync()
    {
        _storySubscription = ActivityNotifier.Subscribe(ActivityStreams.SidebarStory, notification => InvokeAsync(() => HandleSidebarActivityAsync(notification)));
        _chatSubscription = ActivityNotifier.Subscribe(ActivityStreams.SidebarChats, notification => InvokeAsync(() => HandleSidebarActivityAsync(notification)));
        NavigationManager.LocationChanged += HandleLocationChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        _storySubscription?.Dispose();
        _chatSubscription?.Dispose();
        NavigationManager.LocationChanged -= HandleLocationChanged;
        _promptPlaceholderCopyFeedbackCancellation?.Cancel();
        _promptPlaceholderCopyFeedbackCancellation?.Dispose();
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs args) => await InvokeAsync(LoadAsync);

    private Task HandleSidebarActivityAsync(ActivityNotification notification)
    {
        if (notification.EntityId.HasValue
            && _threadId.HasValue
            && notification.EntityId.Value != _threadId.Value)
            return Task.CompletedTask;

        return LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _threadId = await ResolveCurrentThreadIdAsync();
            if (_threadId.HasValue)
            {
                _story = await ChatStoryService.GetSidebarAsync(_threadId.Value, CancellationToken.None);
                if (_story?.SelectedModelId.HasValue == true)
                {
                    _generationSettingsModelId = _story.SelectedModelId;
                    ApplyGenerationSettings(await StoryGenerationSettingsService.GetSettingsAsync(_story.SelectedModelId.Value, CancellationToken.None));
                }
                else
                {
                    _generationSettingsModelId = null;
                    _generationSettings = null;
                }
            }
            else
            {
                _story = null;
                _generationSettings = null;
                _isGenerationSettingsModalOpen = false;
                _isPromptLibraryModalOpen = false;
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private bool IsGenerationSettingsBusy =>
        _isSavingGenerationSettings
        || _isExportingGenerationSettings
        || _isImportingGenerationSettings
        || _isCopyingGenerationSettings;

    private bool CanSaveGenerationSettings =>
        !IsGenerationSettingsBusy
        && _generationSettings is not null
        && TryBuildDraftGenerationSettingsView(out var draftSettings)
        && !AreGenerationSettingsEqual(draftSettings, _generationSettings);

    private async Task<Guid?> ResolveCurrentThreadIdAsync()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (relativePath.StartsWith("chat/", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(relativePath["chat/".Length..], out var threadId))
            return threadId;

        if (!string.IsNullOrWhiteSpace(relativePath))
            return null;

        var recentThreads = await ChatWorkspaceService.GetRecentThreadsAsync(1, CancellationToken.None);
        return recentThreads.FirstOrDefault()?.Id;
    }

    private void OpenCharacterModal()
    {
        _selectedCharacterIdForModal = null;
        _startCharacterModalInCreateMode = false;
        _isCharacterModalOpen = true;
    }

    private void OpenCharacterModal(Guid? characterId)
    {
        _selectedCharacterIdForModal = characterId;
        _startCharacterModalInCreateMode = false;
        _isCharacterModalOpen = true;
    }

    private void OpenLocationsModal()
    {
        _selectedLocationIdForModal = null;
        _isLocationsModalOpen = true;
    }

    private void OpenLocationsModal(Guid? locationId)
    {
        _selectedLocationIdForModal = locationId;
        _isLocationsModalOpen = true;
    }

    private void OpenItemsModal()
    {
        _selectedItemIdForModal = null;
        _isItemsModalOpen = true;
    }

    private void OpenItemsModal(Guid? itemId)
    {
        _selectedItemIdForModal = itemId;
        _isItemsModalOpen = true;
    }

    private void OpenHistoryModal() => _isHistoryModalOpen = true;

    private void OpenImageGalleryModal() => _isImageGalleryModalOpen = true;

    private void OpenImageOptimizationModal() => _isImageOptimizationModalOpen = true;

    private void OpenProviderEditor() => _isProviderEditorOpen = true;

    private async Task OpenPromptLibraryModal()
    {
        if (!_threadId.HasValue)
            return;

        _promptLibraryErrorMessage = null;
        _activePromptLibraryStage = StoryScenePromptStage.Appearance;
        _promptLibraryDefaults = StoryScenePromptLibraryService.GetDefaultLibrary();
        _promptLibrary = await StoryScenePromptLibraryService.GetLibraryAsync(_threadId.Value, CancellationToken.None);
        _promptLibraryDraft = PromptLibraryDraft.FromView(_promptLibrary);
        _isPromptLibraryModalOpen = true;
    }

    private Task CloseProviderEditor()
    {
        _isProviderEditorOpen = false;
        return Task.CompletedTask;
    }

    private void ToggleModelSwitcher() => _isModelSwitcherOpen = !_isModelSwitcherOpen;

    private Task OpenGenerationSettingsModal()
    {
        if (_story?.SelectedModelId is not Guid modelId)
            return Task.CompletedTask;

        return OpenGenerationSettingsModal(modelId);
    }

    private async Task OpenGenerationSettingsModal(Guid modelId)
    {
        _generationSettingsModelId = modelId;
        ApplyGenerationSettings(await StoryGenerationSettingsService.GetSettingsAsync(modelId, CancellationToken.None));
        ApplyGenerationSettingsDraft(_generationSettings!);
        _generationSettingsErrorMessage = null;
        _generationSettingsImportFileName = null;
        _isGenerationSettingsCopyOpen = false;
        ResetGenerationSettingsCopyTargets();
        _isGenerationSettingsModalOpen = true;
    }

    private Task CloseCharacterModal()
    {
        _isCharacterModalOpen = false;
        _selectedCharacterIdForModal = null;
        _startCharacterModalInCreateMode = false;
        return Task.CompletedTask;
    }

    private Task CloseLocationsModal()
    {
        _isLocationsModalOpen = false;
        _selectedLocationIdForModal = null;
        return Task.CompletedTask;
    }

    private Task CloseItemsModal()
    {
        _isItemsModalOpen = false;
        _selectedItemIdForModal = null;
        return Task.CompletedTask;
    }

    private Task CloseHistoryModal()
    {
        _isHistoryModalOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseImageGalleryModal()
    {
        _isImageGalleryModalOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseImageOptimizationModal()
    {
        _isImageOptimizationModalOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseGenerationSettingsModal()
    {
        if (IsGenerationSettingsBusy)
            return Task.CompletedTask;

        _isGenerationSettingsModalOpen = false;
        _generationSettingsErrorMessage = null;
        _generationSettingsImportFileName = null;
        _isGenerationSettingsCopyOpen = false;
        _generationSettingsImportInputKey++;
        if (_generationSettings is not null)
            ApplyGenerationSettingsDraft(_generationSettings);

        return Task.CompletedTask;
    }

    private Task ClosePromptLibraryModal()
    {
        if (IsPromptLibraryBusy)
            return Task.CompletedTask;

        _isPromptLibraryModalOpen = false;
        _promptLibraryErrorMessage = null;
        if (_promptLibrary is not null)
            _promptLibraryDraft = PromptLibraryDraft.FromView(_promptLibrary);

        return Task.CompletedTask;
    }

    private Task HandleStoryChangedAsync() => LoadAsync();

    private async Task SelectSpeakerAsync(StorySidebarSpeakerView speaker)
    {
        if (!_threadId.HasValue)
            return;

        var speakerKey = GetSpeakerKey(speaker.CharacterId);
        if (!_switchingSpeakerKeys.Add(speakerKey))
            return;

        _errorMessage = null;

        try
        {
            await StorySceneChatService.SelectSpeakerAsync(_threadId.Value, speaker.CharacterId, CancellationToken.None);
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Selecting speaker {SpeakerId} failed for chat {ChatId}.", speaker.CharacterId, _threadId.Value);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Selecting {speaker.Name} as the active speaker failed.", exception);
        }
        finally
        {
            _switchingSpeakerKeys.Remove(speakerKey);
            StateHasChanged();
        }
    }

    private async Task SelectAgentAsync(string agentName)
    {
        if (!_threadId.HasValue || !_switchingAgentNames.Add(agentName))
            return;

        _errorMessage = null;

        try
        {
            await ThreadAgentService.SetSelectedAgentAsync(_threadId.Value, agentName, CancellationToken.None);
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Selecting AI provider {AgentName} failed for chat {ChatId}.", agentName, _threadId.Value);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Selecting the AI provider '{agentName}' failed.", exception);
        }
        finally
        {
            _switchingAgentNames.Remove(agentName);
            StateHasChanged();
        }
    }

    private async Task SelectAgentAsync(Guid modelId, string modelName)
    {
        if (!_threadId.HasValue || !_switchingAgentNames.Add(modelName))
            return;

        _errorMessage = null;

        try
        {
            await ThreadAgentService.SetSelectedAgentAsync(_threadId.Value, modelId, CancellationToken.None);
            _isModelSwitcherOpen = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Selecting AI model {ModelId} failed for chat {ChatId}.", modelId, _threadId.Value);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Selecting the AI model '{modelName}' failed.", exception);
        }
        finally
        {
            _switchingAgentNames.Remove(modelName);
            StateHasChanged();
        }
    }

    private async Task SaveGenerationSettingsAsync()
    {
        if (_generationSettings is null || IsGenerationSettingsBusy)
            return;

        _isSavingGenerationSettings = true;
        _errorMessage = null;
        _generationSettingsErrorMessage = null;

        try
        {
            var update = BuildDraftGenerationSettingsUpdate();
            if (!_generationSettingsModelId.HasValue)
                throw new InvalidOperationException("Saving model settings failed because no model is selected.");

            var savedSettings = await StoryGenerationSettingsService.UpdateSettingsAsync(_generationSettingsModelId.Value, update, CancellationToken.None);
            ApplyGenerationSettings(savedSettings);
            _isGenerationSettingsModalOpen = false;
            _generationSettingsErrorMessage = null;
            _generationSettingsImportFileName = null;
            _generationSettingsImportInputKey++;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving story model settings failed.");
            _generationSettingsErrorMessage = DescribeGenerationSettingsFailure(exception, "Saving story model settings failed.");
        }
        finally
        {
            _isSavingGenerationSettings = false;
            StateHasChanged();
        }
    }

    private void SelectGenerationSettingsStage(StoryGenerationStage stage) => _activeGenerationSettingsStage = stage;

    private void SyncActiveGenerationSettingsDraft()
    {
        if (IsGenerationSettingsBusy)
            return;

        if (_activeGenerationSettingsStage == StoryGenerationStage.Planning)
        {
            _writingGenerationSettingsDraft = _planningGenerationSettingsDraft.Clone();
            return;
        }

        _planningGenerationSettingsDraft = _writingGenerationSettingsDraft.Clone();
    }

    private void ToggleGenerationSettingsCopy()
    {
        _isGenerationSettingsCopyOpen = !_isGenerationSettingsCopyOpen;
        if (_isGenerationSettingsCopyOpen)
            ResetGenerationSettingsCopyTargets();
    }

    private void ResetGenerationSettingsCopyTargets()
    {
        _generationSettingsCopyTargets = _story?.AvailableAgents
            .Where(x => x.ModelId != _generationSettingsModelId)
            .ToDictionary(x => x.ModelId, _ => StoryGenerationSettingsCopySlot.Both)
            ?? [];
    }

    private async Task CopyGenerationSettingsAsync()
    {
        if (!_generationSettingsCopyTargets.Any())
            return;

        _isCopyingGenerationSettings = true;
        _generationSettingsErrorMessage = null;

        try
        {
            var settings = BuildDraftStageSettingsView(_activeGenerationSettingsStage);
            var targets = _generationSettingsCopyTargets
                .Select(x => new CopyStoryGenerationSettingsTarget(x.Key, x.Value))
                .ToList();
            await StoryGenerationSettingsService.CopySettingsAsync(_activeGenerationSettingsStage, settings, targets, CancellationToken.None);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Copying {Stage} model settings failed.", _activeGenerationSettingsStage);
            _generationSettingsErrorMessage = DescribeGenerationSettingsFailure(exception, $"Copying {DescribeGenerationStage(_activeGenerationSettingsStage)} model settings failed.");
        }
        finally
        {
            _isCopyingGenerationSettings = false;
            StateHasChanged();
        }
    }

    private async Task ExportGenerationSettingsAsync()
    {
        if (_generationSettings is null || IsGenerationSettingsBusy)
            return;

        _isExportingGenerationSettings = true;
        _generationSettingsErrorMessage = null;

        try
        {
            var stage = _activeGenerationSettingsStage;
            var packageJson = StoryGenerationSettingsService.SerializeStageTransferPackage(stage, BuildDraftStageSettingsView(stage));
            var fileName = StoryGenerationSettingsService.BuildStageExportFileName(stage, DateTime.UtcNow);
            await JSRuntime.InvokeVoidAsync("chatTransfer.downloadJson", fileName, packageJson);
        }
        catch (Exception exception)
        {
            var stage = _activeGenerationSettingsStage;
            Logger.LogError(exception, "Exporting {Stage} model settings failed.", stage);
            _generationSettingsErrorMessage = DescribeGenerationSettingsFailure(
                exception,
                $"Exporting {DescribeGenerationStage(stage)} model settings failed.");
        }
        finally
        {
            _isExportingGenerationSettings = false;
            StateHasChanged();
        }
    }

    private async Task HandleGenerationSettingsImportAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null || IsGenerationSettingsBusy)
            return;

        _isImportingGenerationSettings = true;
        _generationSettingsErrorMessage = null;
        _generationSettingsImportFileName = file.Name;

        try
        {
            using var stream = file.OpenReadStream(1024 * 1024);
            using var reader = new StreamReader(stream);
            var packageJson = await reader.ReadToEndAsync();
            var importedSettings = StoryGenerationSettingsService.DeserializeStageTransferPackage(packageJson, _activeGenerationSettingsStage);
            ApplyDraftStageSettings(_activeGenerationSettingsStage, importedSettings);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Importing {Stage} model settings from {FileName} failed.", _activeGenerationSettingsStage, file.Name);
            _generationSettingsErrorMessage = DescribeGenerationSettingsFailure(
                exception,
                $"Importing {DescribeGenerationStage(_activeGenerationSettingsStage)} model settings from \"{file.Name}\" failed.");
        }
        finally
        {
            _isImportingGenerationSettings = false;
            _generationSettingsImportInputKey++;
            StateHasChanged();
        }
    }

    private async Task ToggleCharacterScenePresenceAsync(StoryCharacterListItemView character)
    {
        if (!_threadId.HasValue || !_togglingCharacterIds.Add(character.CharacterId))
            return;

        _errorMessage = null;

        try
        {
            var charactersTask = ChatStoryService.GetCharactersAsync(_threadId.Value, CancellationToken.None);
            var itemsTask = ChatStoryService.GetItemsAsync(_threadId.Value, CancellationToken.None);
            await Task.WhenAll(charactersTask, itemsTask);

            var presentCharacterIds = charactersTask.Result
                .Where(x => x.IsPresentInScene && x.CharacterId != character.CharacterId)
                .Select(x => x.CharacterId)
                .ToList();
            if (!character.IsPresentInScene)
                presentCharacterIds.Add(character.CharacterId);

            var presentItemIds = itemsTask.Result
                .Where(x => x.IsPresentInScene)
                .Select(x => x.ItemId)
                .ToList();

            await ChatStoryService.UpdateScenePresenceAsync(
                new UpdateScenePresence(_threadId.Value, presentCharacterIds, presentItemIds),
                CancellationToken.None);

            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Updating scene presence for character {CharacterId} failed for chat {ChatId}.", character.CharacterId, _threadId.Value);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Updating scene presence for '{character.Name}' failed.", exception);
        }
        finally
        {
            _togglingCharacterIds.Remove(character.CharacterId);
            StateHasChanged();
        }
    }

    private async Task ToggleItemScenePresenceAsync(StoryItemListItemView item)
    {
        if (!_threadId.HasValue || !_togglingItemIds.Add(item.ItemId))
            return;

        _errorMessage = null;

        try
        {
            var charactersTask = ChatStoryService.GetCharactersAsync(_threadId.Value, CancellationToken.None);
            var itemsTask = ChatStoryService.GetItemsAsync(_threadId.Value, CancellationToken.None);
            await Task.WhenAll(charactersTask, itemsTask);

            var presentCharacterIds = charactersTask.Result
                .Where(x => x.IsPresentInScene)
                .Select(x => x.CharacterId)
                .ToList();
            var presentItems = itemsTask.Result
                .Where(x => x.IsPresentInScene)
                .ToList();
            var isPresentInScene = presentItems.Any(x => x.ItemId == item.ItemId);
            var presentItemIds = presentItems
                .Where(x => x.ItemId != item.ItemId)
                .Select(x => x.ItemId)
                .ToList();
            if (!isPresentInScene)
                presentItemIds.Add(item.ItemId);

            await ChatStoryService.UpdateScenePresenceAsync(
                new UpdateScenePresence(_threadId.Value, presentCharacterIds, presentItemIds),
                CancellationToken.None);

            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Updating scene presence for item {ItemId} failed for chat {ChatId}.", item.ItemId, _threadId.Value);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Updating scene presence for '{item.Name}' failed.", exception);
        }
        finally
        {
            _togglingItemIds.Remove(item.ItemId);
            StateHasChanged();
        }
    }

