    private async Task ManageEndpointAsync(AgentEndpointStatusView endpoint, ManagedAgentAction action)
    {
        if (!_managingEndpointAgentNames.Add(endpoint.AgentName))
            return;

        var actionKey = BuildManagedEndpointActionKey(endpoint.AgentName, action);
        _managingEndpointActionKeys.Add(actionKey);
        _errorMessage = null;

        try
        {
            await AgentEndpointManagementService.ExecuteActionAsync(endpoint.AgentName, action, CancellationToken.None);
            await LoadAsync();
            UserFeedbackService.ShowBackgroundSuccess(
                $"{DescribeManagedEndpointAction(action)} the Hugging Face endpoint for '{endpoint.AgentName}' completed.",
                "Endpoint Updated");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Running endpoint action {Action} failed for agent {AgentName}.", action, endpoint.AgentName);
            _errorMessage = $"{DescribeManagedEndpointAction(action)} the Hugging Face endpoint for '{endpoint.AgentName}' failed.";
            UserFeedbackService.ShowBackgroundError(_errorMessage, "Endpoint Update Failed");
        }
        finally
        {
            _managingEndpointActionKeys.Remove(actionKey);
            _managingEndpointAgentNames.Remove(endpoint.AgentName);
            StateHasChanged();
        }
    }

