    private async Task SavePromptLibraryAsync()
    {
        if (!_threadId.HasValue || _promptLibraryDraft is null || IsPromptLibraryBusy)
            return;

        _isSavingPromptLibrary = true;
        _promptLibraryErrorMessage = null;

        try
        {
            var saved = await StoryScenePromptLibraryService.SaveLibraryAsync(
                new UpdateStoryScenePromptLibrary(_threadId.Value, _promptLibraryDraft.ToView()),
                CancellationToken.None);
            _promptLibrary = saved;
            _promptLibraryDraft = PromptLibraryDraft.FromView(saved);
            _isPromptLibraryModalOpen = false;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving prompt library failed for chat {ChatId}.", _threadId);
            _promptLibraryErrorMessage = UserFacingErrorMessageBuilder.Build("Saving the prompt library failed.", exception);
        }
        finally
        {
            _isSavingPromptLibrary = false;
            StateHasChanged();
        }
    }

    private async Task CopyPromptPlaceholderAsync(string token)
    {
        _promptLibraryErrorMessage = null;
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", token);
            _copiedPromptPlaceholderToken = token;
            _promptPlaceholderCopyFeedbackCancellation?.Cancel();
            _promptPlaceholderCopyFeedbackCancellation?.Dispose();
            _promptPlaceholderCopyFeedbackCancellation = new CancellationTokenSource();
            _ = ClearPromptPlaceholderCopyFeedbackAsync(_promptPlaceholderCopyFeedbackCancellation.Token);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Copying prompt placeholder failed.");
            _promptLibraryErrorMessage = UserFacingErrorMessageBuilder.Build($"Copying placeholder '{token}' failed.", exception);
        }
    }

    private async Task ClearPromptPlaceholderCopyFeedbackAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
            _copiedPromptPlaceholderToken = null;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

