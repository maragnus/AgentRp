    private bool IsManagingEndpoint(string agentName) => _managingEndpointAgentNames.Contains(agentName);

    private bool IsManagingEndpointAction(string agentName, ManagedAgentAction action) =>
        _managingEndpointActionKeys.Contains(BuildManagedEndpointActionKey(agentName, action));

    private void EnsureManagedEndpointPolling()
    {
        if (SelectedManagedEndpoint is null && !ShouldShowManagedEndpointError)
        {
            StopManagedEndpointPolling();
            return;
        }

        if (_managedEndpointPollingCancellationTokenSource is not null)
            return;

        _managedEndpointPollingCancellationTokenSource = new CancellationTokenSource();
        _managedEndpointPollingTask = PollManagedEndpointsAsync(_managedEndpointPollingCancellationTokenSource.Token);
    }

    private void StopManagedEndpointPolling()
    {
        _managedEndpointPollingCancellationTokenSource?.Cancel();
        _managedEndpointPollingCancellationTokenSource?.Dispose();
        _managedEndpointPollingCancellationTokenSource = null;
        _managedEndpointPollingTask = null;
    }

    private async Task PollManagedEndpointsAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                try
                {
                    await InvokeAsync(LoadAsync);
                }
                catch (Exception exception)
                {
                    Logger.LogError(exception, "Refreshing Hugging Face endpoint status from the sidebar poller failed.");
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

