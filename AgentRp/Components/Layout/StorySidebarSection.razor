    private void ApplyGenerationSettings(StoryGenerationSettingsView settings)
    {
        _generationSettings = settings;
        if (!_isGenerationSettingsModalOpen || IsGenerationSettingsBusy)
            ApplyGenerationSettingsDraft(settings);
    }

    private void ApplyGenerationSettingsDraft(StoryGenerationSettingsView settings)
    {
        _planningGenerationSettingsDraft = StoryModelStageSettingsDraft.FromView(settings.Planning);
        _writingGenerationSettingsDraft = StoryModelStageSettingsDraft.FromView(settings.Writing);
    }

    private void ApplyDraftStageSettings(StoryGenerationStage stage, StoryModelStageSettingsView settings)
    {
        if (stage == StoryGenerationStage.Planning)
        {
            _planningGenerationSettingsDraft = StoryModelStageSettingsDraft.FromView(settings);
            return;
        }

        _writingGenerationSettingsDraft = StoryModelStageSettingsDraft.FromView(settings);
    }

    private UpdateStoryGenerationSettings BuildDraftGenerationSettingsUpdate() => new(
        BuildDraftStageSettingsView(StoryGenerationStage.Planning),
        BuildDraftStageSettingsView(StoryGenerationStage.Writing));

    private StoryGenerationSettingsView BuildDraftGenerationSettingsView() => new(
        BuildDraftStageSettingsView(StoryGenerationStage.Planning),
        BuildDraftStageSettingsView(StoryGenerationStage.Writing));

    private bool TryBuildDraftGenerationSettingsView(out StoryGenerationSettingsView settings)
    {
        try
        {
            settings = BuildDraftGenerationSettingsView();
            return true;
        }
        catch
        {
            settings = _generationSettings ?? new StoryGenerationSettingsView(
                BuildDraftStageSettingsViewWithoutNormalization(StoryGenerationStage.Planning),
                BuildDraftStageSettingsViewWithoutNormalization(StoryGenerationStage.Writing));
            return false;
        }
    }

    private StoryModelStageSettingsView BuildDraftStageSettingsView(StoryGenerationStage stage)
    {
        var draft = BuildDraftStageSettingsViewWithoutNormalization(stage);
        return StoryGenerationSettingsService.NormalizeStageSettings(stage, draft);
    }

    private StoryModelStageSettingsView BuildDraftStageSettingsViewWithoutNormalization(StoryGenerationStage stage)
    {
        var draft = GetGenerationSettingsDraft(stage);
        return new StoryModelStageSettingsView(
            draft.Temperature,
            draft.TopP,
            draft.MaxOutputTokens,
            draft.Seed,
            draft.FrequencyPenalty,
            draft.PresencePenalty,
            SplitStopSequences(draft.StopSequencesText));
    }

    private StoryModelStageSettingsDraft GetGenerationSettingsDraft(StoryGenerationStage stage) =>
        stage == StoryGenerationStage.Planning
            ? _planningGenerationSettingsDraft
            : _writingGenerationSettingsDraft;

