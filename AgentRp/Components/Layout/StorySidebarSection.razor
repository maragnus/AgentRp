    private bool ShouldShowManagedEndpointError =>
        _story is not null
        && !string.IsNullOrWhiteSpace(_story.ManagedAgentEndpointsErrorMessage)
        && _story.AvailableAgents.Any(x =>
            x.ProviderKind == AgentProviderKind.HuggingFaceInferenceEndpoint
