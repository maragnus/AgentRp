                                                 IsStopping="@IsStoppingRun(ActiveRunningProcess!.RunId)"
                                                 Disabled="@IsStoppingRun(ActiveRunningProcess!.RunId)"
                                                 Title="Stop the active scene generation"
                                                 OnClick="() => StopSceneRunAsync(ActiveRunningProcess!.RunId)" />
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <StoryChatSnapshotModal IsOpen="@_isSnapshotModalOpen"
                            IsLoading="@_isSnapshotDraftLoading"
                            IsCommitting="@_isCommittingSnapshot"
                            Draft="@_snapshotDraft"
                            EmptyStateMessage="@_snapshotDraftStatusMessage"
                            CloseDisabled="@(_isSnapshotDraftLoading || _isCommittingSnapshot)"
                            CanStop="@(_isSnapshotDraftLoading && _snapshotDraftOperation is not null)"
                            IsStopping="@_isStoppingSnapshotDraft"
                            OnStop="StopSnapshotDraftAsync"
                            OnClose="CloseSnapshotDraftAsync"
