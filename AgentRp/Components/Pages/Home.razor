                ? new AdaptiveAiPostAction(
                    StoryScenePostMode.RespondGuidedAi,
                    "Respond Guided",
                    "Respond Guided chooses another present character and uses your guidance",
                    "fa-regular fa-reply me-2")
                : new AdaptiveAiPostAction(
                    StoryScenePostMode.RespondAutomaticAi,
                    "Respond Automatic",
                    "Respond Automatic chooses another present character and ignores the textbox",
                    "fa-regular fa-reply-all me-2");
        }

        return HasDraftText
            ? new AdaptiveAiPostAction(
                StoryScenePostMode.GuidedAi,
                "Guided",
