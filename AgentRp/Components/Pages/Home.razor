    private async Task SaveInlineEditAsync()
    {
        if (_chat is null || !_editingMessageId.HasValue || string.IsNullOrWhiteSpace(_editingDraft))
            return;

        var editingMessage = _chat.Transcript
            .Select(x => x.Message)
            .FirstOrDefault(x => x?.MessageId == _editingMessageId.Value);
        if (editingMessage is null || !editingMessage.CanSaveInPlace)
        {
            _errorMessage = "This message is already covered by a snapshot and can only be edited by creating a branch.";
            return;
        }

        _isSubmitting = true;
        _editingAction = StorySceneEditAction.Save;
        _errorMessage = null;

        try
        {
            await StorySceneChatService.UpdateMessageAsync(
                new ChatMessageUpdate(_chat.ThreadId, _editingMessageId.Value, _editingDraft),
                CancellationToken.None);

            var editedMessageId = _editingMessageId.Value;
            CancelInlineEdit();
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving edited story scene message {MessageId} failed for chat {ThreadId}.", _editingMessageId, _chat.ThreadId);
            _errorMessage = "Saving the edited message failed.";
        }
        finally
        {
            _isSubmitting = false;
            _editingAction = null;
        }
    }

    private async Task CreateEditedBranchAsync()
    {
        if (_chat is null || !_editingMessageId.HasValue || string.IsNullOrWhiteSpace(_editingDraft))
            return;

        _isSubmitting = true;
        _editingAction = StorySceneEditAction.Branch;
        _errorMessage = null;

        try
        {
            await StorySceneChatService.CreateBranchAsync(
                new BranchStorySceneMessage(_chat.ThreadId, _editingMessageId.Value, _editingDraft),
                CancellationToken.None);

            CancelInlineEdit();
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Creating edited branch from message {MessageId} failed for chat {ThreadId}.", _editingMessageId, _chat.ThreadId);
            _errorMessage = "Submitting the edited message as a new branch failed.";
        }
        finally
        {
            _isSubmitting = false;
            _editingAction = null;
        }
    }

    private async Task SelectBranchAsync(Guid leafMessageId)
    {
        if (_chat is null)
            return;

        _isSubmitting = true;
        _switchingBranchLeafId = leafMessageId;
        _errorMessage = null;

        try
