                        <div class="col-12 col-lg-8">
                            <label class="form-label" for="story-plan-beat">Beat</label>
                            <textarea id="story-plan-beat"
                                      class="form-control"
                                      rows="2"
                                      @bind="_planDraftBeat"
                                      disabled="@_isSubmitting"></textarea>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label" for="story-plan-intent">Intent</label>
                            <textarea id="story-plan-intent"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftIntent"
                                      disabled="@_isSubmitting"></textarea>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label" for="story-plan-goal">Immediate goal</label>
                            <textarea id="story-plan-goal"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftImmediateGoal"
                                      disabled="@_isSubmitting"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-why-now">Why now</label>
                            <textarea id="story-plan-why-now"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftWhyNow"
                                      disabled="@_isSubmitting"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-change">Change introduced</label>
                            <textarea id="story-plan-change"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftChangeIntroduced"
                                      disabled="@_isSubmitting"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-guardrails">Guardrails</label>
                            <textarea id="story-plan-guardrails"
                                      class="form-control"
                                      rows="5"
                                      @bind="_planDraftGuardrails"
                                      disabled="@_isSubmitting"></textarea>
                            <div class="form-text">Optional. Use one guardrail per line.</div>
                        </div>
                    </div>
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@_isSubmitting"
                    @onclick="ClosePlanModalAsync">
                Cancel
            </button>

            <BusyButton Class="btn btn-primary"
                        OnClick="SavePlanEditAsync"
                        IsBusy="@_isSubmitting"
                        BusyText="Saving..."
                        Disabled="@(!CanSavePlanEdit || !_isPlanModalOpen)">
                Save
            </BusyButton>
        </FooterContent>
    </AppModal>

    <AppModal IsOpen="@_isDeleteModalOpen"
              Title="@DeleteModalTitle"
              DialogClass="modal-dialog modal-dialog-centered modal-fullscreen-sm-down"
              OnClose="CloseDeleteModal">
        <ChildContent>
            @if (_deleteTargetMessage is not null)
            {
                <div class="d-flex flex-column gap-3">
                    <div class="alert alert-warning mb-0">@DeleteModalSummary</div>

                    <div class="small text-body-secondary">
                        @_deleteTargetMessage.DisplaySpeakerName on @_deleteTargetMessage.CreatedUtc.ToShorthandDateWithRelativeDays()
                    </div>

                    <div class="border rounded bg-body-tertiary px-3 py-3">
                        @if (_deleteTargetMessage.IsNarrator)
                        {
                            <div class="fst-italic">@_deleteTargetMessage.Content</div>
                        }
                        else
                        {
                            <div>@_deleteTargetMessage.Content</div>
                        }
                    </div>

                    @if (_deleteTargetMessage.DeleteCapabilities.CanDeleteBranch)
                    {
                        <div class="small text-body-secondary">
                            Deleting this branch removes @_deleteTargetMessage.DeleteCapabilities.DescendantCount descendant @BranchDescendantLabel in addition to the selected message.
                        </div>
                    }
                    else
                    {
                        <div class="small text-body-secondary">
                            This message has no descendant branch, so only the selected message will be removed.
                        </div>
                    }
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@_isSubmitting"
                    @onclick="CloseDeleteModal">
                Cancel
            </button>

            @if (_deleteTargetMessage is not null)
            {
                <BusyButton Class="btn btn-outline-danger"
                            OnClick='() => ConfirmDeleteAsync(StorySceneDeleteMode.SingleMessage)'
                            IsBusy="@(_isSubmitting && _deleteMode == StorySceneDeleteMode.SingleMessage)"
                            BusyText="Deleting..."
                            Disabled="@(!_deleteTargetMessage.DeleteCapabilities.CanDeleteSingleMessage || (_isSubmitting && _deleteMode != StorySceneDeleteMode.SingleMessage))">
                    Delete Message Only
                </BusyButton>

                @if (_deleteTargetMessage.DeleteCapabilities.CanDeleteBranch)
                {
                    <BusyButton Class="btn btn-danger"
                                OnClick='() => ConfirmDeleteAsync(StorySceneDeleteMode.Branch)'
                                IsBusy="@(_isSubmitting && _deleteMode == StorySceneDeleteMode.Branch)"
                                BusyText="Deleting..."
                                Disabled="@(_isSubmitting && _deleteMode != StorySceneDeleteMode.Branch)">
                        Delete Branch
                    </BusyButton>
                }
            }
        </FooterContent>
    </AppModal>
}

@code {
    [Parameter]
    public Guid? ChatId { get; set; }

    [CascadingParameter]
    private AppShellState? ShellState { get; set; }

    private IDisposable? _workspaceSubscription;
    private Guid? _appliedThreadId;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private StoryScenePostMode? _submittingMode;
    private string _draftText = string.Empty;
    private Guid? _retrySourceMessageId;
    private string? _retrySpeakerName;
    private Guid? _startingRetryMessageId;
    private Guid? _regeneratingProseMessageId;
    private Guid? _editingMessageId;
    private string _editingDraft = string.Empty;
    private StorySceneEditAction? _editingAction;
    private Guid? _editingAppearanceEntryId;
    private Dictionary<Guid, string> _appearanceDrafts = [];
    private Guid? _switchingBranchLeafId;
    private bool _isSnapshotModalOpen;
    private bool _isSnapshotDraftLoading;
    private bool _isCommittingSnapshot;
    private StoryChatSnapshotDraftView? _snapshotDraft;
    private bool _isPlanModalOpen;
    private Guid? _editingPlanMessageId;
    private string? _editingPlanSpeakerName;
    private StoryTurnShape _planDraftTurnShape = StoryTurnShape.Compact;
    private string _planDraftBeat = string.Empty;
    private string _planDraftIntent = string.Empty;
    private string _planDraftImmediateGoal = string.Empty;
    private string _planDraftWhyNow = string.Empty;
    private string _planDraftChangeIntroduced = string.Empty;
    private string _planDraftGuardrails = string.Empty;
    private string? _planEditErrorMessage;
    private bool _isDeleteModalOpen;
    private StorySceneMessageView? _deleteTargetMessage;
    private StorySceneDeleteMode? _deleteMode;
    private string? _errorMessage;
    private StorySceneChatState? _chat;
    private DateTime _processDurationNowUtc = DateTime.UtcNow;
    private readonly Dictionary<Guid, bool> _expandedProcessRunStates = [];
    private readonly Dictionary<Guid, bool> _expandedProcessAppearanceStates = [];
    private readonly Dictionary<Guid, bool> _expandedProcessTraceStates = [];
    private readonly Dictionary<Guid, Guid?> _expandedProcessStepIds = [];
    private readonly Dictionary<Guid, bool> _expandedSnapshotStates = [];
    private readonly Dictionary<Guid, string> _streamedMessageContent = [];
    private readonly HashSet<Guid> _stoppingRunIds = [];
    private System.Threading.Timer? _processDurationRefreshTimer;
    private IModelOperationHandle? _snapshotDraftOperation;
    private bool _isStoppingSnapshotDraft;
    private string? _snapshotDraftStatusMessage;
    private bool HasDraftText => !string.IsNullOrWhiteSpace(_draftText);
    private StorySceneMessageProcessView? ActiveRunningProcess =>
        _chat?.Transcript
            .Select(x => x.Message?.Process)
            .FirstOrDefault(x => x?.Status == ProcessRunStatus.Running);
    private bool HasRunningSceneProcess => ActiveRunningProcess is not null;
    private bool IsSceneInteractionLocked => _isSubmitting || HasRunningSceneProcess;

    protected override async Task OnInitializedAsync()
    {
        _workspaceSubscription = ActivityNotifier.Subscribe(ActivityStreams.StoryChatWorkspace, _ => InvokeAsync(HandleWorkspaceUpdatedAsync));
        await base.OnInitializedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var requestedThreadId = ChatId;
        var resolvedThreadId = await ChatWorkspaceService.ResolveWorkspaceThreadAsync(requestedThreadId, CancellationToken.None);

        if (requestedThreadId != resolvedThreadId)
        {
            NavigationManager.NavigateTo($"/chat/{resolvedThreadId}", replace: true);
            return;
        }

        if (_appliedThreadId != resolvedThreadId || _chat is null)
        {
            _isLoading = true;
            ClearRetryState(clearDraft: false);
            await LoadChatAsync(resolvedThreadId);
            _appliedThreadId = resolvedThreadId;
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _workspaceSubscription?.Dispose();
        _processDurationRefreshTimer?.Dispose();
    }

    private async Task HandleWorkspaceUpdatedAsync()
    {
        if (_appliedThreadId.HasValue)
            await LoadChatAsync(_appliedThreadId.Value);
    }

    private async Task LoadChatAsync(Guid threadId)
    {
        _chat = await StorySceneChatService.GetChatStateAsync(threadId, CancellationToken.None);
        _processDurationNowUtc = DateTime.UtcNow;

        if (_chat is not null)
        {
            foreach (var process in _chat.Transcript.Select(x => x.Message).Where(x => x?.Process is not null).Select(x => x!.Process!))
            {
                _expandedProcessRunStates.TryAdd(process.RunId, false);
                _expandedProcessAppearanceStates.TryAdd(process.RunId, false);
                _expandedProcessTraceStates.TryAdd(process.RunId, false);
                _expandedProcessStepIds.TryAdd(process.RunId, null);
            }

            foreach (var snapshot in _chat.Transcript.Select(x => x.Snapshot).Where(x => x is not null).Select(x => x!))
                _expandedSnapshotStates.TryAdd(snapshot.SnapshotId, false);

            if (_editingAppearanceEntryId.HasValue
                && !_chat.Transcript.Any(x => x.Appearance?.AppearanceEntryId == _editingAppearanceEntryId.Value))
                CancelAppearanceEdit();
            if (_editingPlanMessageId.HasValue)
            {
                var editingPlanMessage = _chat.Transcript
                    .Select(x => x.Message)
                    .FirstOrDefault(x => x?.MessageId == _editingPlanMessageId.Value);
                if (editingPlanMessage is null || !CanEditSavedPlan(editingPlanMessage))
                    ResetPlanEditState();
            }

            ClearStaleRetryState();
            ShellState?.SetMobileContentHeader(_chat.Title, MessageCountText);
        }

        SyncStoppingRuns();
        SyncProcessDurationRefreshTimer();
        StateHasChanged();
    }

    private async Task HandleMessageStreamUpdateAsync(StorySceneMessageStreamUpdate update, CancellationToken cancellationToken)
    {
        if (_chat is null || _chat.ThreadId != update.ThreadId)
            return;

        await InvokeAsync(async () =>
        {
            if (_chat is null || _chat.ThreadId != update.ThreadId)
                return;

            if (!_chat.Transcript.Any(x => x.Message?.MessageId == update.MessageId))
                await LoadChatAsync(update.ThreadId);

            if (string.IsNullOrWhiteSpace(update.Content))
                _streamedMessageContent.Remove(update.MessageId);
            else
                _streamedMessageContent[update.MessageId] = update.Content;

            StateHasChanged();
        });
    }

    private string GetDisplayContent(StorySceneMessageView message) =>
        _streamedMessageContent.TryGetValue(message.MessageId, out var streamedContent)
            ? streamedContent
            : message.Content;

    private void ClearStreamedMessageContent()
    {
        if (_streamedMessageContent.Count == 0)
            return;

        _streamedMessageContent.Clear();
        StateHasChanged();
    }

    private void SyncProcessDurationRefreshTimer()
    {
        var hasRunningProcesses = _chat?.Transcript.Any(x => x.Message?.Process?.Status == ProcessRunStatus.Running) == true;

        if (hasRunningProcesses)
        {
            _processDurationRefreshTimer ??= new System.Threading.Timer(_ => RefreshProcessDurations(), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
            return;
        }

        _processDurationRefreshTimer?.Dispose();
        _processDurationRefreshTimer = null;
    }

    private void RefreshProcessDurations()
    {
        _processDurationNowUtc = DateTime.UtcNow;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task PostAsync(StoryScenePostMode mode)
    {
        if (_chat is null)
            return;

        _errorMessage = null;

        if (mode != StoryScenePostMode.Manual && !_chat.IsAiAvailable)
        {
            _errorMessage = "This chat does not currently have an AI provider configured.";
            return;
        }

        if (RequiresGuidance(mode) && !HasDraftText)
        {
            _errorMessage = mode == StoryScenePostMode.Manual
                ? "Enter a message before posting."
                : "Enter a guidance prompt before generating the message.";
            return;
        }

        if (HasRunningSceneProcess)
        {
            _errorMessage = "Stop the active scene generation before starting another one.";
            return;
        }

        _submittingMode = mode;
        _isSubmitting = true;
        var retrySourceMessageId = _retrySourceMessageId;

        try
        {
            await StorySceneChatService.PostMessageAsync(
                new PostStorySceneMessage(
                    _chat.ThreadId,
                    _chat.SelectedSpeaker.CharacterId,
                    mode,
                    mode == StoryScenePostMode.Manual ? _draftText : null,
                    UsesGuidance(mode) ? _draftText : null,
                    retrySourceMessageId),
                mode == StoryScenePostMode.Manual ? null : HandleMessageStreamUpdateAsync,
                CancellationToken.None);

            if (!IgnoresDraft(mode))
                _draftText = string.Empty;
            ClearRetryState(clearDraft: false);
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            if (mode != StoryScenePostMode.Manual)
                UserFeedbackService.ShowBackgroundSuccess(BuildPostSuccessMessage(mode), "Scene Updated");
        }
        catch (OperationCanceledException)
        {
            if (mode != StoryScenePostMode.Manual)
            {
                await LoadChatAsync(_chat.ThreadId);
                ClearStreamedMessageContent();
            }

            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Posting scene message failed for chat {ThreadId}.", _chat.ThreadId);
            if (mode != StoryScenePostMode.Manual)
            {
                await LoadChatAsync(_chat.ThreadId);
                ClearStreamedMessageContent();
            }

            _errorMessage = exception.Message;
            if (mode != StoryScenePostMode.Manual)
                UserFeedbackService.ShowBackgroundError(_errorMessage, "Scene Message Failed");
            else if (retrySourceMessageId.HasValue)
                UserFeedbackService.ShowBackgroundError(_errorMessage, "Retry Failed");
        }
        finally
        {
            _isSubmitting = false;
            _submittingMode = null;
        }
    }

    private async Task BeginRetryAsync(StorySceneMessageView message)
    {
        if (_chat is null || IsSceneInteractionLocked || !CanRetryMessage(message))
            return;

        _isSubmitting = true;
        _startingRetryMessageId = message.MessageId;
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            _retrySourceMessageId = message.MessageId;
            _retrySpeakerName = message.CanonicalSpeakerName;
            _draftText = BuildRetryDraftText(message);

            await StorySceneChatService.SelectSpeakerAsync(_chat.ThreadId, message.SpeakerCharacterId, CancellationToken.None);
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Preparing retry from story scene message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            ClearRetryState(clearDraft: false);
            _errorMessage = $"Preparing retry for '{message.CanonicalSpeakerName}' failed.";
            UserFeedbackService.ShowBackgroundError(_errorMessage, "Retry Failed");
        }
        finally
        {
            _isSubmitting = false;
            _startingRetryMessageId = null;
        }
    }

    private void CancelRetry() => ClearRetryState(clearDraft: false);

    private void ClearRetryState(bool clearDraft)
    {
        _retrySourceMessageId = null;
        _retrySpeakerName = null;
        _startingRetryMessageId = null;

        if (clearDraft)
            _draftText = string.Empty;
    }

    private void ClearStaleRetryState()
    {
        if (!_retrySourceMessageId.HasValue)
            return;

        var retryMessageIsInTranscript = _chat?.Transcript.Any(x => x.Message?.MessageId == _retrySourceMessageId.Value) == true;
        if (retryMessageIsInTranscript)
            return;

        ClearRetryState(clearDraft: false);
    }

    private bool CanRetryMessage(StorySceneMessageView message) =>
        message.Process?.Status != ProcessRunStatus.Running;

    private bool CanRegenerateProse(StorySceneMessageView message) =>
        HasReusableSavedPlan(message);

    private bool CanEditSavedPlan(StorySceneMessageView message) =>
        HasReusableSavedPlan(message);

    private static bool HasReusableSavedPlan(StorySceneMessageView message) =>
        message.GenerationMode != StoryScenePostMode.Manual
        && message.Process?.Status != ProcessRunStatus.Running
        && message.Process?.Context is { GenerationContext: not null, Appearance: not null, Planner: not null };

    private async Task RegenerateProseAsync(StorySceneMessageView message)
    {
        if (_chat is null || IsSceneInteractionLocked || !CanRegenerateProse(message))
            return;

        _isSubmitting = true;
        _regeneratingProseMessageId = message.MessageId;
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            ClearRetryState(clearDraft: false);

            await StorySceneChatService.RegenerateProseAsync(
                new RegenerateStorySceneProse(_chat.ThreadId, message.MessageId),
                HandleMessageStreamUpdateAsync,
                CancellationToken.None);

            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            UserFeedbackService.ShowBackgroundSuccess($"The prose was regenerated for {message.CanonicalSpeakerName}.", "Scene Updated");
        }
        catch (OperationCanceledException)
        {
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Regenerating prose from story scene message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = exception.Message;
            UserFeedbackService.ShowBackgroundError(_errorMessage, "Prose Regeneration Failed");
        }
        finally
        {
            _isSubmitting = false;
            _regeneratingProseMessageId = null;
        }
    }

    private static string BuildRetryDraftText(StorySceneMessageView message)
    {
        return message.GenerationMode switch
        {
            StoryScenePostMode.Manual => message.Content,
            StoryScenePostMode.GuidedAi or StoryScenePostMode.RespondGuidedAi => message.Process?.Context?.GuidancePrompt?.Trim() ?? string.Empty,
            StoryScenePostMode.AutomaticAi or StoryScenePostMode.RespondAutomaticAi => string.Empty,
            _ => string.Empty
        };
    }

    private void OpenPlanModal(StorySceneMessageView message)
    {
        if (!CanEditSavedPlan(message) || message.Process?.Context?.Planner is not { } planner)
            return;

        CancelInlineEdit();
        CancelAppearanceEdit();
        ClearRetryState(clearDraft: false);
        _editingPlanMessageId = message.MessageId;
        _editingPlanSpeakerName = message.CanonicalSpeakerName;
        _planDraftTurnShape = planner.TurnShape;
        _planDraftBeat = planner.Beat;
        _planDraftIntent = planner.Intent;
        _planDraftImmediateGoal = planner.ImmediateGoal;
        _planDraftWhyNow = planner.WhyNow;
        _planDraftChangeIntroduced = planner.ChangeIntroduced;
        _planDraftGuardrails = string.Join(Environment.NewLine, planner.Guardrails);
        _planEditErrorMessage = null;
        _isPlanModalOpen = true;
    }

    private Task ClosePlanModalAsync()
    {
        if (_isSubmitting)
            return Task.CompletedTask;

        ResetPlanEditState();
        return Task.CompletedTask;
    }

    private void ResetPlanEditState()
    {
        _isPlanModalOpen = false;
        _editingPlanMessageId = null;
        _editingPlanSpeakerName = null;
        _planDraftTurnShape = StoryTurnShape.Compact;
        _planDraftBeat = string.Empty;
        _planDraftIntent = string.Empty;
        _planDraftImmediateGoal = string.Empty;
        _planDraftWhyNow = string.Empty;
        _planDraftChangeIntroduced = string.Empty;
        _planDraftGuardrails = string.Empty;
        _planEditErrorMessage = null;
    }

    private async Task SavePlanEditAsync()
    {
        if (_chat is null || !CanSavePlanEdit || !_editingPlanMessageId.HasValue)
            return;

        var message = EditingPlanMessage;
        if (message is null || !CanEditSavedPlan(message))
        {
            _planEditErrorMessage = "The saved plan could not be updated for the selected message.";
            return;
        }

        _isSubmitting = true;
        _planEditErrorMessage = null;
        _errorMessage = null;

        try
        {
            await StorySceneChatService.UpdatePlanAsync(
                new UpdateStoryScenePlan(
                    _chat.ThreadId,
                    message.MessageId,
                    new StoryMessagePlannerResult(
                        _planDraftTurnShape,
                        _planDraftBeat,
                        _planDraftIntent,
                        _planDraftImmediateGoal,
                        _planDraftWhyNow,
                        _planDraftChangeIntroduced,
                        NormalizePlanDraftGuardrails())),
                CancellationToken.None);

            var speakerName = message.CanonicalSpeakerName;
            ResetPlanEditState();
            await LoadChatAsync(_chat.ThreadId);
            UserFeedbackService.ShowBackgroundSuccess($"The saved plan was updated for {speakerName}.", "Plan Updated");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Updating the saved plan for message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            _planEditErrorMessage = "The saved plan could not be updated for the selected message.";
            UserFeedbackService.ShowBackgroundError(_planEditErrorMessage, "Plan Update Failed");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

