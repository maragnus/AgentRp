@page "/"
@page "/chat/{ChatId:guid}"
@inject IChatWorkspaceService ChatWorkspaceService
@inject NavigationManager NavigationManager

<PageTitle>Story Scene Chat</PageTitle>

@if (_isResolving)
{
    <div class="d-flex h-100 align-items-center justify-content-center px-3 py-4">
        <div class="d-flex align-items-center gap-3">
            <div class="spinner-border" role="status"></div>
            <span>Loading story scene chat...</span>
        </div>
    </div>
}
else if (_resolvedThreadId.HasValue)
{
    <StorySceneChatWorkspace ThreadId="@_resolvedThreadId.Value" />
}

@code {
    [Parameter]
    public Guid? ChatId { get; set; }

    private Guid? _resolvedThreadId;
    private bool _isResolving = true;

    protected override async Task OnParametersSetAsync()
    {
        _isResolving = true;
        var resolvedThreadId = await ChatWorkspaceService.ResolveWorkspaceThreadAsync(ChatId, CancellationToken.None);

        if (ChatId != resolvedThreadId)
        {
            NavigationManager.NavigateTo($"/chat/{resolvedThreadId}", replace: true);
            return;
        }

        _resolvedThreadId = resolvedThreadId;
        _isResolving = false;
    }
}
