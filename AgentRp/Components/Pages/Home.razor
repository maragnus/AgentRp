    private async Task OpenSnapshotDraftAsync(StorySceneMessageView message)
    {
        if (_chat is null || !message.IsSnapshotCandidate)
            return;

        _snapshotDraftOperation?.Dispose();
        _snapshotDraftOperation = ModelOperationRegistry.Start();
        _isSnapshotModalOpen = true;
        _isSnapshotDraftLoading = true;
        _isStoppingSnapshotDraft = false;
        _snapshotDraft = null;
        _snapshotDraftStatusMessage = null;
        _errorMessage = null;

        try
        {
            _snapshotDraft = await StoryChatSnapshotService.CreateDraftAsync(
                new CreateStoryChatSnapshotDraft(
                    _chat.ThreadId,
                    message.MessageId),
                _snapshotDraftOperation.CancellationToken);
        }
        catch (OperationCanceledException)
        {
            _snapshotDraftStatusMessage = "Snapshot draft generation was stopped.";
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Creating the snapshot draft failed for chat {ThreadId}.", _chat.ThreadId);
            _snapshotDraftStatusMessage = "Creating the snapshot draft failed.";
            _errorMessage = "Creating the snapshot draft failed.";
        }
        finally
        {
            _isSnapshotDraftLoading = false;
            _isStoppingSnapshotDraft = false;
            _snapshotDraftOperation?.Dispose();
            _snapshotDraftOperation = null;
        }
    }

    private Task CloseSnapshotDraftAsync()
    {
        if (_isSnapshotDraftLoading || _isCommittingSnapshot)
            return Task.CompletedTask;

        _isSnapshotModalOpen = false;
        _isSnapshotDraftLoading = false;
        _snapshotDraft = null;
        _snapshotDraftStatusMessage = null;
        return Task.CompletedTask;
    }

    private async Task CommitSnapshotDraftAsync(CommitStoryChatSnapshotDraft request)
    {
        if (_chat is null)
            return;

        _isCommittingSnapshot = true;
        _errorMessage = null;

        try
        {
            await StoryChatSnapshotService.CommitDraftAsync(request, CancellationToken.None);
            _isSnapshotModalOpen = false;
            _snapshotDraft = null;
            _snapshotDraftStatusMessage = null;
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Committing the snapshot draft failed for chat {ThreadId}.", _chat.ThreadId);
            _errorMessage = "Committing the snapshot draft failed.";
            UserFeedbackService.ShowBackgroundError(_errorMessage, "Snapshot Commit Failed");
        }
        finally
        {
            _isCommittingSnapshot = false;
        }
    }

    private Task StopSnapshotDraftAsync()
    {
        if (_snapshotDraftOperation is null || _isStoppingSnapshotDraft)
            return Task.CompletedTask;

        _isStoppingSnapshotDraft = true;
        if (ModelOperationRegistry.TryCancel(_snapshotDraftOperation.OperationId))
            UserFeedbackService.ShowBackgroundInfo("Stopping the snapshot draft generation.", "Stopping");
        else
            _isStoppingSnapshotDraft = false;

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteAsync(StorySceneDeleteMode mode)
    {
        if (_chat is null || _deleteTargetMessage is null)
            return;

        _isSubmitting = true;
        _deleteMode = mode;
        _errorMessage = null;

        try
        {
            var targetMessage = _deleteTargetMessage;

            await StorySceneChatService.DeleteMessageAsync(
                new DeleteStorySceneMessage(_chat.ThreadId, targetMessage.MessageId, mode),
                CancellationToken.None);

            _isDeleteModalOpen = false;
            _deleteTargetMessage = null;
            _deleteMode = null;
            ClearRetryState(clearDraft: false);
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Deleting story scene message {MessageId} failed for chat {ThreadId}.", _deleteTargetMessage?.MessageId, _chat.ThreadId);
            _errorMessage = mode == StorySceneDeleteMode.Branch
                ? "Deleting the selected branch failed."
                : "Deleting the selected message failed.";
        }
        finally
        {
            _isSubmitting = false;
            _deleteMode = null;
        }
    }

