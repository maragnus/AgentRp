                                    BusyText="Generating..."
                                    Disabled="@(!_chat.IsAiAvailable || (IsSceneInteractionLocked && _submittingMode != selectedSpeakerAiPostAction.Mode))"
                                    ShowBusyText="false"
                                    title="@selectedSpeakerAiPostAction.Title"
                                    aria-label="@selectedSpeakerAiPostAction.Title">
                            <i class="@selectedSpeakerAiPostAction.IconCssClass" aria-hidden="true"></i>
                            @selectedSpeakerAiPostAction.Label
                        </BusyButton>

                        <BusyButton Class="btn btn-outline-primary"
                                    OnClick="() => PostAsync(respondAiPostAction.Mode)"
                                    IsBusy="@(_submittingMode == respondAiPostAction.Mode)"
                                    BusyText="Generating..."
                                    Disabled="@(!_chat.IsAiAvailable || (IsSceneInteractionLocked && _submittingMode != respondAiPostAction.Mode))"
                                    ShowBusyText="false"
                                    title="@respondAiPostAction.Title"
                                    aria-label="@respondAiPostAction.Title">
                            <i class="@respondAiPostAction.IconCssClass" aria-hidden="true"></i>
                            @respondAiPostAction.Label
                        </BusyButton>

                        <BusyButton Class="btn btn-outline-primary"
                                    OnClick="() => PostAsync(StoryScenePostMode.Manual)"
                                    IsBusy="@(_submittingMode == StoryScenePostMode.Manual)"
                                    BusyText="Posting..."
                                    Disabled="@(!HasDraftText || (IsSceneInteractionLocked && _submittingMode != StoryScenePostMode.Manual))"
                                    ShowBusyText="false"
                                    title="Direct posts your exact text"
                                    aria-label="Direct posts your exact text">
                            <i class="fa-regular fa-paper-plane" aria-hidden="true"></i>
