    private static RenderFragment RenderSnapshotReferences(string label, IReadOnlyList<string> names) => builder =>
    {
        if (names.Count == 0)
            return;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "small mt-2");
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "text-body-secondary me-2");
        builder.AddContent(4, $"{label}:");
        builder.CloseElement();

        for (var index = 0; index < names.Count; index++)
        {
            builder.OpenElement(5 + (index * 3), "span");
            builder.AddAttribute(6 + (index * 3), "class", "badge text-bg-light border text-body-secondary me-1");
            builder.AddContent(7 + (index * 3), names[index]);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private enum StorySceneEditAction
    {
        Save,
        Branch
    }
}
