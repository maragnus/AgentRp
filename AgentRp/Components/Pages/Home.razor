                                                                            <div class="small text-body-secondary mt-1">@entry.Summary</div>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(entry.Details))
                                                                        {
                                                                            <div class="small mt-1">@entry.Details</div>
