        step.StartedUtc.HasValue ? step.StartedUtc.Value.ToDurationText(step.CompletedUtc, _processDurationNowUtc) : null;

    private static string GetProcessStepSubtitle(StorySceneMessageProcessView process, StorySceneProcessStepView step)
    {
        if (IsAppearanceProcessStep(step)
            && !string.IsNullOrWhiteSpace(process.Context?.Appearance?.LatestEntry?.Summary))
            return process.Context.Appearance.LatestEntry.Summary;

        if (IsResponderProcessStep(step)
            && process.Context?.ResponderSelection is not null)
            return $"{process.Context.ResponderSelection.CharacterName}: {process.Context.ResponderSelection.WhyThisCharacter}";

        if (string.Equals(step.Title, "Writing", StringComparison.OrdinalIgnoreCase)
            && process.Context?.Planner is not null)
            return $"{process.Context.Planner.Beat}: {process.Context.Planner.ImmediateGoal}";

        return step.Summary;
    }

    private static IReadOnlyList<StoryMessageProcessTextBlock> GetProcessStepBlocks(StorySceneProcessStepView step)
    {
        if (step.Artifact is null)
            return [];

        return step.Artifact.Inputs
            .Concat(step.Artifact.Outputs)
            .Where(block => !string.IsNullOrWhiteSpace(block.Content))
            .ToList();
    }

    private static bool IsAppearanceProcessStep(StorySceneProcessStepView step) =>
        string.Equals(step.Title, "Appearance", StringComparison.OrdinalIgnoreCase);

    private static bool IsResponderProcessStep(StorySceneProcessStepView step) =>
        string.Equals(step.Title, "Responder", StringComparison.OrdinalIgnoreCase);

