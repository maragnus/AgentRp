        process.Context?.Appearance?.LatestEntry;

    private static IReadOnlyList<StorySceneCharacterAppearanceView> GetProcessAppearanceCharacters(StorySceneMessageProcessView process)
    {
        var latestEntryCharacters = process.Context?.Appearance?.LatestEntry?.Characters;
        if (latestEntryCharacters?.Count > 0)
            return latestEntryCharacters;

        return process.Context?.Appearance?.EffectiveCharacters ?? [];
    }

    private static string GetProcessAppearanceSectionSubtitle(StorySceneMessageProcessView process)
    {
        var appearanceEntry = GetProcessAppearanceEntry(process);
        if (!string.IsNullOrWhiteSpace(appearanceEntry?.Summary))
            return appearanceEntry.Summary;

        return process.Context?.Appearance is not null
            ? "Current scene appearance is ready to review."
            : "Current appearance is still being resolved.";
