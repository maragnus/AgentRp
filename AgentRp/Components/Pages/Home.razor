                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="flex-shrink-0 border-top bg-body px-3 py-3 px-lg-4">
            @if (!_chat.IsAiAvailable)
            {
                <div class="alert alert-info">Configure AI to enable chat functionality.</div>
