                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="alert alert-danger mb-3">@_errorMessage</div>
                }

                @if (_retrySourceMessageId.HasValue)
                {
                    <div class="alert alert-primary d-flex align-items-start justify-content-between gap-3 py-2 mb-3" role="status">
                        <div>
                            <div class="fw-semibold">Retrying message as @_retrySpeakerName</div>
