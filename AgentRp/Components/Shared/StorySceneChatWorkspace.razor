        _isSavingPrivateIntent = true;
        _privateIntentEditErrorMessage = null;
        _errorMessage = null;

        try
        {
            await StorySceneChatService.UpdatePrivateIntentAsync(
                new UpdateStoryScenePrivateIntent(_chat.ThreadId, message.MessageId, _privateIntentDraft),
                CancellationToken.None);

            ResetPrivateIntentEditState();
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Updating private intent for message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            _privateIntentEditErrorMessage = UserFacingErrorMessageBuilder.Build("Updating private intent failed.", exception);
        }
        finally
