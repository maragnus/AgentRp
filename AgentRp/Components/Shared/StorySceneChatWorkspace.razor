@using System.Text
@implements IAsyncDisposable
@inject IStorySceneChatService StorySceneChatService
@inject IStoryChatSnapshotService StoryChatSnapshotService
@inject IStoryChatAppearanceReplayService StoryChatAppearanceReplayService
@inject IActivityNotifier ActivityNotifier
@inject IModelOperationRegistry ModelOperationRegistry
@inject IStorySceneChatDisplayPreferencesService StorySceneChatDisplayPreferencesService
@inject ILogger<StorySceneChatWorkspace> Logger
@inject IJSRuntime JSRuntime
@inject IUserFeedbackService UserFeedbackService

@if (_isLoading)
{
    <div class="d-flex h-100 align-items-center justify-content-center px-3 py-4">
        <div class="d-flex align-items-center gap-3">
            <div class="spinner-border" role="status"></div>
            <span>Loading story scene chat...</span>
        </div>
    </div>
}
else if (_chat is null)
{
    <div class="p-3 p-lg-4">
        <div class="alert alert-danger mb-0">The selected story chat could not be loaded.</div>
    </div>
}
else
{
    <div class="app-chat-workspace d-flex h-100 flex-column bg-body shadow-sm">
        <div class="app-chat-header flex-shrink-0 border-bottom bg-body px-3 py-3 px-lg-4">
            <div class="d-flex flex-wrap align-items-start gap-3">
                <div>
                    <h1 class="h5 mb-1">@_chat.Title</h1>
                    <div class="small text-body-secondary">
                        <span>@(_chat.CurrentLocationName ?? "No current location")</span>
                        <span class="mx-2">•</span>
                        <span>@MessageCountText</span>
                    </div>
                </div>
            </div>
        </div>

        <ChatLog Context="@BuildChatLogContext()" Actions="@BuildChatActions()" MessageDesign="ChatMessageDesign.Classic" />
    </div>

    <StoryChatSnapshotModal IsOpen="@_isSnapshotModalOpen"
                            IsLoading="@_isSnapshotDraftLoading"
                            IsCommitting="@_isCommittingSnapshot"
                            Draft="@_snapshotDraft"
                            EmptyStateMessage="@_snapshotDraftStatusMessage"
                            CloseDisabled="@(_isSnapshotDraftLoading || _isCommittingSnapshot)"
                            CanStop="@(_isSnapshotDraftLoading && _snapshotDraftOperation is not null)"
                            IsStopping="@_isStoppingSnapshotDraft"
                            OnStop="StopSnapshotDraftAsync"
                            OnClose="CloseSnapshotDraftAsync"
                            OnCommit="CommitSnapshotDraftAsync" />

    <StoryChatAppearanceReplayModal IsOpen="@_isAppearanceReplayModalOpen"
                                    IsLoading="@_isAppearanceReplayLoading"
                                    IsSaving="@_isSavingAppearanceReplay"
                                    ErrorMessage="@_appearanceReplayStatusMessage"
                                    Replay="@_appearanceReplay"
                                    OnClose="CloseAppearanceReplayAsync"
                                    OnSave="SaveAppearanceReplayStepAsync" />

    <StorySceneAppearanceEditorModal IsOpen="@_isMessageAppearanceModalOpen"
                                     IsSaving="@_isSavingMessageAppearance"
                                     ThreadId="@_chat.ThreadId"
                                     Message="@EditingMessageAppearanceMessage"
                                     Appearance="@EditingMessageAppearance"
                                     PreviousAppearance="@PreviousMessageAppearance"
                                     EmptyCharacters="@PresentAppearanceCharacters"
                                     ErrorMessage="@_messageAppearanceEditErrorMessage"
                                     OnClose="CloseMessageAppearanceModalAsync"
                                     OnSave="SaveMessageAppearanceAsync" />

    <AppModal IsOpen="@_isPlanModalOpen"
              Title="@PlanModalTitle"
              DialogClass="modal-xl modal-dialog-scrollable modal-fullscreen-sm-down"
              CloseDisabled="@_isSavingPlanEdit"
              OnClose="ClosePlanModalAsync">
        <ChildContent>
            @if (EditingPlanMessage is not null)
            {
                <div class="d-flex flex-column gap-3">
                    <InlineAlert Message="@_planEditErrorMessage" />

                    <div class="small text-body-secondary">
                        @_editingPlanSpeakerName on @EditingPlanMessage.CreatedUtc.ToShorthandDateWithRelativeDays()
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            <label class="form-label" for="story-plan-turn-shape">Turn shape</label>
                            <select id="story-plan-turn-shape"
                                    class="form-select"
                                    @bind="_planDraftTurnShape"
                                    disabled="@_isSavingPlanEdit">
                                @foreach (var turnShape in Enum.GetValues<StoryTurnShape>())
                                {
                                    <option @key="turnShape" value="@turnShape">@FormatTurnShapeOption(turnShape)</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-lg-8">
                            <label class="form-label" for="story-plan-beat">Beat</label>
                            <textarea id="story-plan-beat"
                                      class="form-control"
                                      rows="2"
                                      @bind="_planDraftBeat"
                                      disabled="@_isSavingPlanEdit"></textarea>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label" for="story-plan-intent">Intent</label>
                            <textarea id="story-plan-intent"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftIntent"
                                      disabled="@_isSavingPlanEdit"></textarea>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label" for="story-plan-goal">Immediate goal</label>
                            <textarea id="story-plan-goal"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftImmediateGoal"
                                      disabled="@_isSavingPlanEdit"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-why-now">Why now</label>
                            <textarea id="story-plan-why-now"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftWhyNow"
                                      disabled="@_isSavingPlanEdit"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-change">Change introduced</label>
                            <textarea id="story-plan-change"
                                      class="form-control"
                                      rows="3"
                                      @bind="_planDraftChangeIntroduced"
                                      disabled="@_isSavingPlanEdit"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="story-plan-guardrails">Guardrails</label>
                            <textarea id="story-plan-guardrails"
                                      class="form-control"
                                      rows="5"
                                      @bind="_planDraftNarrativeGuardrails"
                                      disabled="@_isSavingPlanEdit"></textarea>
                            <div class="form-text">Optional. Use one guardrail per line.</div>
                        </div>
                    </div>
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@_isSavingPlanEdit"
                    @onclick="ClosePlanModalAsync">
                Cancel
            </button>

            <BusyButton Class="btn btn-primary"
                        OnClick="SavePlanEditAsync"
                        IsBusy="@_isSavingPlanEdit"
                        BusyText="Saving..."
                        Disabled="@(!CanSavePlanEdit || !_isPlanModalOpen)">
                Save
            </BusyButton>
        </FooterContent>
    </AppModal>

    <AppModal IsOpen="@_isPrivateIntentModalOpen"
              Title="@PrivateIntentModalTitle"
              DialogClass="modal-lg modal-dialog-scrollable modal-fullscreen-sm-down"
              CloseDisabled="@_isSavingPrivateIntent"
              OnClose="ClosePrivateIntentModalAsync">
        <ChildContent>
            @if (EditingPrivateIntentMessage is not null)
            {
                <div class="d-flex flex-column gap-3">
                    <InlineAlert Message="@_privateIntentEditErrorMessage" />

                    <div class="small text-body-secondary">
                        @EditingPrivateIntentMessage.CanonicalSpeakerName on @EditingPrivateIntentMessage.CreatedUtc.ToShorthandDateWithRelativeDays()
                    </div>

                    <div>
                        <label class="form-label" for="story-private-intent">Private Intent</label>
                        <textarea id="story-private-intent"
                                  class="form-control"
                                  rows="8"
                                  @bind="_privateIntentDraft"
                                  disabled="@_isSavingPrivateIntent"></textarea>
                    </div>
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@_isSavingPrivateIntent"
                    @onclick="ClosePrivateIntentModalAsync">
                Cancel
            </button>

            <BusyButton Class="btn btn-primary"
                        OnClick="SavePrivateIntentEditAsync"
                        IsBusy="@_isSavingPrivateIntent"
                        BusyText="Saving..."
                        Disabled="@(!_isPrivateIntentModalOpen || !_editingPrivateIntentMessageId.HasValue)">
                Save
            </BusyButton>
        </FooterContent>
    </AppModal>

    <AppModal IsOpen="@_isDeleteModalOpen"
              Title="@DeleteModalTitle"
              DialogClass="modal-dialog modal-dialog-centered modal-fullscreen-sm-down"
              OnClose="CloseDeleteModal">
        <ChildContent>
            @if (_deleteTargetMessage is not null)
            {
                <div class="d-flex flex-column gap-3">
                    <div class="alert alert-warning mb-0">@DeleteModalSummary</div>

                    <div class="small text-body-secondary">
                        @_deleteTargetMessage.DisplaySpeakerName on @_deleteTargetMessage.CreatedUtc.ToShorthandDateWithRelativeDays()
                    </div>

                    <div class="border rounded bg-body-tertiary px-3 py-3">
                        @if (_deleteTargetMessage.IsNarrator)
                        {
                            <div class="fst-italic">@_deleteTargetMessage.Content</div>
                        }
                        else
                        {
                            <div>@_deleteTargetMessage.Content</div>
                        }
                    </div>

                    @if (_deleteTargetMessage.DeleteCapabilities.CanDeleteBranch)
                    {
                        <div class="small text-body-secondary">
                            Deleting this branch removes @_deleteTargetMessage.DeleteCapabilities.DescendantCount descendant @BranchDescendantLabel in addition to the selected message.
                        </div>
                    }
                    else
                    {
                        <div class="small text-body-secondary">
                            This message has no descendant branch, so only the selected message will be removed.
                        </div>
                    }
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@_isSubmitting"
                    @onclick="CloseDeleteModal">
                Cancel
            </button>

            @if (_deleteTargetMessage is not null)
            {
                <BusyButton Class="btn btn-outline-danger"
                            OnClick='() => ConfirmDeleteAsync(StorySceneDeleteMode.SingleMessage)'
                            IsBusy="@(_isSubmitting && _deleteMode == StorySceneDeleteMode.SingleMessage)"
                            BusyText="Deleting..."
                            Disabled="@(!_deleteTargetMessage.DeleteCapabilities.CanDeleteSingleMessage || (_isSubmitting && _deleteMode != StorySceneDeleteMode.SingleMessage))">
                    Delete Message Only
                </BusyButton>

                @if (_deleteTargetMessage.DeleteCapabilities.CanDeleteBranch)
                {
                    <BusyButton Class="btn btn-danger"
                                OnClick='() => ConfirmDeleteAsync(StorySceneDeleteMode.Branch)'
                                IsBusy="@(_isSubmitting && _deleteMode == StorySceneDeleteMode.Branch)"
                                BusyText="Deleting..."
                                Disabled="@(_isSubmitting && _deleteMode != StorySceneDeleteMode.Branch)">
                        Delete Branch
                    </BusyButton>
                }
            }
        </FooterContent>
    </AppModal>
}

@code {
    [Parameter]
    public Guid ThreadId { get; set; }

    [CascadingParameter]
    private AppShellState? ShellState { get; set; }

    private IDisposable? _workspaceSubscription;
    private const string AutoselectAuthorKey = "autoselect";
    private Guid? _appliedThreadId;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private StoryScenePostMode? _submittingMode;
    private string? _submittingAuthorKey;
    private StoryTurnShape? _submittingTurnShape;
    private string _draftText = string.Empty;
    private Guid? _retrySourceMessageId;
    private Guid? _retryBranchMessageId;
    private string? _retrySpeakerName;
    private Guid? _startingRetryMessageId;
    private Guid? _reassigningMessageId;
    private string? _reassigningAuthorKey;
    private Guid? _regeneratingProseMessageId;
    private Guid? _changingTurnShapeMessageId;
    private StoryTurnShape? _changingTurnShapeValue;
    private Guid? _editingMessageId;
    private Guid? _selectedMessageId;
    private string _editingDraft = string.Empty;
    private StorySceneEditAction? _editingAction;
    private Guid? _editingAppearanceEntryId;
    private Guid? _savingAppearanceEntryId;
    private Dictionary<Guid, string> _appearanceDrafts = [];
    private Guid? _switchingBranchLeafId;
    private bool _isSnapshotModalOpen;
    private bool _isSnapshotDraftLoading;
    private bool _isCommittingSnapshot;
    private bool _isAppearanceReplayModalOpen;
    private bool _isAppearanceReplayLoading;
    private bool _isSavingAppearanceReplay;
    private bool _isUpdatingDisplayPreferences;
    private StoryChatSnapshotDraftView? _snapshotDraft;
    private StoryChatAppearanceReplayView? _appearanceReplay;
    private bool _isPlanModalOpen;
    private bool _isSavingPlanEdit;
    private Guid? _editingPlanMessageId;
    private string? _editingPlanSpeakerName;
    private StoryTurnShape _planDraftTurnShape = StoryTurnShape.Compact;
    private string _planDraftBeat = string.Empty;
    private string _planDraftIntent = string.Empty;
    private string _planDraftImmediateGoal = string.Empty;
    private string _planDraftWhyNow = string.Empty;
    private string _planDraftChangeIntroduced = string.Empty;
    private string _planDraftNarrativeGuardrails = string.Empty;
    private string _planDraftContentGuardrails = string.Empty;
    private string? _planEditErrorMessage;
    private bool _isPrivateIntentModalOpen;
    private bool _isSavingPrivateIntent;
    private Guid? _editingPrivateIntentMessageId;
    private string _privateIntentDraft = string.Empty;
    private string? _privateIntentEditErrorMessage;
    private bool _isMessageAppearanceModalOpen;
    private bool _isSavingMessageAppearance;
    private Guid? _editingMessageAppearanceMessageId;
    private string? _messageAppearanceEditErrorMessage;
    private bool _isDeleteModalOpen;
    private StorySceneMessageView? _deleteTargetMessage;
    private StorySceneDeleteMode? _deleteMode;
    private string? _errorMessage;
    private StorySceneChatState? _chat;
    private bool _showProcessPanels = true;
    private Guid? _copyingProcessStepId;
    private Guid? _copiedProcessStepId;
    private readonly Dictionary<Guid, bool> _expandedProcessRunStates = [];
    private readonly Dictionary<Guid, bool> _expandedProcessTraceStates = [];
    private readonly Dictionary<Guid, Guid?> _expandedProcessStepIds = [];
    private readonly Dictionary<Guid, bool> _expandedSnapshotStates = [];
    private readonly Dictionary<Guid, bool> _expandedAppearanceEntryStates = [];
    private readonly Dictionary<Guid, string> _streamedMessageContent = [];
    private readonly HashSet<Guid> _stoppingRunIds = [];
    private IModelOperationHandle? _snapshotDraftOperation;
    private CancellationTokenSource? _processStepCopyFeedbackCancellation;
    private ElementReference _chatLogScrollContainer;
    private ElementReference _chatComposerFooter;
    private IJSObjectReference? _chatComposerScrollSnap;
    private bool _hasChatLogScrollContainer;
    private bool _hasChatComposerFooter;
    private bool _isRegisteringChatComposerScrollSnap;
    private bool _scrollChatLogToBottom;
    private bool _isStoppingSnapshotDraft;
    private string? _snapshotDraftStatusMessage;
    private string? _appearanceReplayStatusMessage;
    private bool HasDraftText => !string.IsNullOrWhiteSpace(_draftText);
    private StorySceneMessageProcessView? ActiveRunningProcess =>
        _chat?.Transcript
            .Select(x => x.Message?.Process)
            .FirstOrDefault(x => x?.Status == ProcessRunStatus.Running);
    private bool HasRunningSceneProcess => ActiveRunningProcess is not null;
    private bool IsSceneInteractionLocked => _isSubmitting || HasRunningSceneProcess;

    private ChatLogContext BuildChatLogContext()
    {
        var chat = _chat ?? throw new InvalidOperationException("Chat state is required to build the chat log context.");
        return new(chat, BuildTranscriptItemContexts(chat), BuildChatLogFooterContext(chat));
    }

    private IReadOnlyList<ChatTranscriptItemContext> BuildTranscriptItemContexts(StorySceneChatState chat)
    {
        var items = new List<ChatTranscriptItemContext>();

        foreach (var node in chat.Transcript)
        {
            var message = node.Message;
            var process = message?.Process;
            var snapshot = node.Snapshot;
            var appearance = node.Appearance;
            var processContext = process is null
                ? null
                : new ChatProcessTraceContext(
                    process,
                    _showProcessPanels,
                    IsProcessTraceExpanded(process.RunId),
                    GetExpandedStepId(process.RunId),
                    _copyingProcessStepId,
                    _copiedProcessStepId);
            var messageContext = message is null ? null : BuildChatMessageContext(chat, message);
            var snapshotContext = snapshot is null ? null : new ChatSnapshotContext(snapshot, IsSnapshotExpanded(snapshot.SnapshotId));
            var appearanceContext = appearance is null
                ? null
                : new ChatAppearanceEntryContext(
                    appearance,
                    _showProcessPanels,
                    IsAppearanceEntryExpanded(appearance.AppearanceEntryId),
                    _editingAppearanceEntryId == appearance.AppearanceEntryId,
                    _savingAppearanceEntryId);

            if (messageContext is null
                && processContext is null
                && snapshotContext is null
                && (appearanceContext is null || !appearanceContext.IsVisible))
                continue;

            items.Add(new(
                BuildTranscriptItemKey(node),
                processContext,
                messageContext,
                snapshotContext,
                appearanceContext));
        }

        return items;
    }

    private ChatMessageContext BuildChatMessageContext(StorySceneChatState chat, StorySceneMessageView message)
    {
        var canRetryMessage = CanRetryMessage(message);
        var canRegenerateProse = CanRegenerateProse(message);
        var canEditSavedPlan = CanEditSavedPlan(message);
        var footer = new ChatMessageFooterContext(
            message,
            chat.AvailableSpeakers,
            _editingMessageId == message.MessageId,
            _isSubmitting,
            IsSceneInteractionLocked,
            _switchingBranchLeafId,
            _reassigningMessageId,
            _reassigningAuthorKey,
            _startingRetryMessageId,
            _regeneratingProseMessageId,
            _changingTurnShapeMessageId,
            _changingTurnShapeValue,
            _isSnapshotDraftLoading,
            _isCommittingSnapshot,
            canRetryMessage,
            canRegenerateProse,
            canEditSavedPlan,
            message.Process?.Context?.Planner?.TurnShape,
            _editingMessageId.HasValue,
            _editingDraft,
            _isSubmitting && _editingAction == StorySceneEditAction.Save,
            _isSubmitting && _editingAction == StorySceneEditAction.Branch);

        return new(
            message,
            message.Process,
            GetDisplayContent(message),
            BuildMessageCardClass(message),
            _editingMessageId == message.MessageId,
            _editingDraft,
            _isSubmitting,
            IsSceneInteractionLocked,
            footer);
    }

    private ChatLogFooterContext BuildChatLogFooterContext(StorySceneChatState chat) =>
        new(
            chat,
            _draftText,
            _errorMessage,
            _retrySourceMessageId.HasValue,
            _retrySpeakerName,
            _isSubmitting,
            IsSceneInteractionLocked,
            _isAppearanceReplayLoading,
            _isUpdatingDisplayPreferences,
            _showProcessPanels,
            !_retrySourceMessageId.HasValue,
            _submittingMode,
            _submittingAuthorKey,
            _submittingTurnShape,
            ActiveRunningProcess);

    private StorySceneChatActions BuildChatActions() => new()
    {
        Post = (mode, turnShape) => RunChatActionAsync(() => PostAsync(mode, turnShape)),
        RespondAs = author => RunChatActionAsync(() => PostRespondAsAsync(author)),
        RespondAutoselect = () => RunChatActionAsync(PostRespondAutoselectAsync),
        SetDraftText = value => RunChatActionAsync(() => SetDraftTextAsync(value)),
        CancelRetry = () => RunChatActionAsync(CancelRetryAsync),
        OpenAppearanceReplay = () => RunChatActionAsync(OpenAppearanceReplayAsync),
        ToggleProcessPanels = () => RunChatActionAsync(ToggleProcessPanelsAsync),
        StopSceneRun = runId => RunChatActionAsync(() => StopSceneRunAsync(runId)),
        IsStoppingRun = IsStoppingRun,
        ChatLogScrollContainerChanged = SetChatLogScrollContainer,
        ChatLogFooterElementChanged = SetChatComposerFooter,
        SelectBranch = EventCallback.Factory.Create<Guid>(this, (Guid leafMessageId) => RunChatActionAsync(() => SelectBranchAsync(leafMessageId))),
        ToggleSelectedMessage = messageId => RunChatAction(() => ToggleSelectedMessage(messageId)),
        SetEditingDraft = value => RunChatActionAsync(() => SetEditingDraftAsync(value)),
        CancelInlineEdit = () => RunChatActionAsync(CancelInlineEditAsync),
        SaveInlineEdit = () => RunChatActionAsync(SaveInlineEditAsync),
        CreateEditedBranch = () => RunChatActionAsync(CreateEditedBranchAsync),
        ChangeMessageSpeaker = (message, speaker) => RunChatActionAsync(() => ChangeMessageSpeakerAsync(message, speaker)),
        BeginRetry = message => RunChatActionAsync(() => BeginRetryAsync(message)),
        OpenPrivateIntent = message => RunChatAction(() => OpenPrivateIntentModal(message)),
        OpenMessageAppearance = message => RunChatAction(() => OpenMessageAppearanceModal(message)),
        RegenerateProse = message => RunChatActionAsync(() => RegenerateProseAsync(message)),
        ChangeTurnShapeAndRegenerate = (message, turnShape) => RunChatActionAsync(() => ChangeTurnShapeAndRegenerateAsync(message, turnShape)),
        OpenPlan = message => RunChatAction(() => OpenPlanModal(message)),
        OpenSnapshotDraft = message => RunChatActionAsync(() => OpenSnapshotDraftAsync(message)),
        BeginInlineEdit = message => RunChatAction(() => BeginInlineEdit(message)),
        CopyMessage = content => RunChatActionAsync(() => CopyMessageAsync(content)),
        OpenDelete = message => RunChatAction(() => OpenDeleteModal(message)),
        ToggleProcessTrace = runId => RunChatAction(() => ToggleProcessTrace(runId)),
        ToggleProcessStep = (runId, stepId) => RunChatAction(() => ToggleProcessStep(runId, stepId)),
        CopyProcessStep = (step, textBlocks) => RunChatActionAsync(() => CopyProcessStepAsync(step, textBlocks)),
        ToggleSnapshot = snapshotId => RunChatAction(() => ToggleSnapshot(snapshotId)),
        ToggleAppearanceEntry = appearanceEntryId => RunChatAction(() => ToggleAppearanceEntry(appearanceEntryId)),
        BeginAppearanceEdit = appearance => RunChatAction(() => BeginAppearanceEdit(appearance)),
        CancelAppearanceEdit = () => RunChatActionAsync(CancelAppearanceEditAsync),
        GetAppearanceDraft = GetAppearanceDraft,
        SetAppearanceDraft = (appearanceEntryId, value) => RunChatAction(() => SetAppearanceDraft(appearanceEntryId, value)),
        SaveAppearanceEdit = appearance => RunChatActionAsync(() => SaveAppearanceEditAsync(appearance))
    };

    private async Task RunChatActionAsync(Func<Task> action)
    {
        await action();
        StateHasChanged();
    }

    private void RunChatAction(Action action)
    {
        action();
        StateHasChanged();
    }

    private static object BuildTranscriptItemKey(StorySceneTranscriptNodeView node)
    {
        if (node.Message is not null)
            return node.Message.MessageId;

        if (node.Snapshot is not null)
            return node.Snapshot.SnapshotId;

        if (node.Appearance is not null)
            return node.Appearance.AppearanceEntryId;

        return node.Sequence;
    }

    protected override async Task OnInitializedAsync()
    {
        _workspaceSubscription = ActivityNotifier.Subscribe(ActivityStreams.StoryChatWorkspace, notification => InvokeAsync(() => HandleWorkspaceUpdatedAsync(notification)));
        await LoadDisplayPreferencesAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_appliedThreadId != ThreadId || _chat is null)
        {
            _isLoading = true;
            ClearRetryState(clearDraft: false);
            await LoadChatAsync(ThreadId);
            _appliedThreadId = ThreadId;
            _isLoading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _workspaceSubscription?.Dispose();
        _snapshotDraftOperation?.Dispose();
        _processStepCopyFeedbackCancellation?.Cancel();
        _processStepCopyFeedbackCancellation?.Dispose();

        if (_chatComposerScrollSnap is null)
            return;

        try
        {
            await _chatComposerScrollSnap.InvokeVoidAsync("dispose");
            await _chatComposerScrollSnap.DisposeAsync();
        }
        catch (JSDisconnectedException exception)
        {
            Logger.LogDebug(exception, "Skipping chat composer scroll snap disposal because the browser circuit is disconnected.");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await CompleteChatLogElementWorkAsync();
    }

    private async Task RegisterChatComposerScrollSnapAsync()
    {
        if (_chat is null
            || _chatComposerScrollSnap is not null
            || _isRegisteringChatComposerScrollSnap
            || !_hasChatLogScrollContainer
            || !_hasChatComposerFooter)
            return;

        _isRegisteringChatComposerScrollSnap = true;

        try
        {
            _chatComposerScrollSnap = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "agentRp.registerInlineFooterScrollSnap",
                _chatLogScrollContainer,
                _chatComposerFooter);
        }
        catch (JSDisconnectedException exception)
        {
            Logger.LogDebug(exception, "Skipping chat composer scroll snap registration because the browser circuit is disconnected.");
        }
        finally
        {
            _isRegisteringChatComposerScrollSnap = false;
        }
    }

    private async Task CompleteChatLogElementWorkAsync()
    {
        await RegisterChatComposerScrollSnapAsync();

        if (!_scrollChatLogToBottom || !_hasChatLogScrollContainer)
            return;

        _scrollChatLogToBottom = false;

        try
        {
            await JSRuntime.InvokeVoidAsync("agentRp.scrollToBottom", _chatLogScrollContainer);
        }
        catch (JSDisconnectedException exception)
        {
            Logger.LogDebug(exception, "Skipping chat log scroll because the browser circuit is disconnected.");
        }
    }

    private async Task HandleWorkspaceUpdatedAsync(ActivityNotification notification)
    {
        if (notification.EntityId.HasValue
            && _appliedThreadId.HasValue
            && notification.EntityId.Value != _appliedThreadId.Value)
            return;

        if (_appliedThreadId.HasValue)
            await LoadChatAsync(_appliedThreadId.Value);
    }

    private async Task LoadChatAsync(Guid threadId)
    {
        var previousThreadId = _chat?.ThreadId;
        var previousMessageCount = GetTranscriptMessageCount(_chat);
        _chat = await StorySceneChatService.GetChatStateAsync(threadId, CancellationToken.None);

        if (_chat is not null)
        {
            if (previousThreadId != _chat.ThreadId || GetTranscriptMessageCount(_chat) > previousMessageCount)
                ScheduleChatLogScrollToBottom();

            foreach (var process in _chat.Transcript.Select(x => x.Message).Where(x => x?.Process is not null).Select(x => x!.Process!))
            {
                _expandedProcessRunStates.TryAdd(process.RunId, false);
                _expandedProcessTraceStates.TryAdd(process.RunId, false);
                _expandedProcessStepIds.TryAdd(process.RunId, null);
            }

            foreach (var snapshot in _chat.Transcript.Select(x => x.Snapshot).Where(x => x is not null).Select(x => x!))
                _expandedSnapshotStates.TryAdd(snapshot.SnapshotId, false);

            foreach (var appearance in _chat.Transcript.Select(x => x.Appearance).Where(x => x is not null).Select(x => x!))
                _expandedAppearanceEntryStates.TryAdd(appearance.AppearanceEntryId, false);

            if (_editingAppearanceEntryId.HasValue
                && !_chat.Transcript.Any(x => x.Appearance?.AppearanceEntryId == _editingAppearanceEntryId.Value))
                CancelAppearanceEdit();
            if (_selectedMessageId.HasValue
                && !_chat.Transcript.Any(x => x.Message?.MessageId == _selectedMessageId.Value))
                _selectedMessageId = null;
            if (_editingPlanMessageId.HasValue)
            {
                var editingPlanMessage = _chat.Transcript
                    .Select(x => x.Message)
                    .FirstOrDefault(x => x?.MessageId == _editingPlanMessageId.Value);
                if (editingPlanMessage is null || !CanEditSavedPlan(editingPlanMessage))
                    ResetPlanEditState();
            }
            if (_editingPrivateIntentMessageId.HasValue
                && !_chat.Transcript.Any(x => x.Message?.MessageId == _editingPrivateIntentMessageId.Value))
                ResetPrivateIntentEditState();

            ClearStaleRetryState();
            ShellState?.SetMobileContentHeader(_chat.Title, MessageCountText);
        }

        SyncStoppingRuns();
        StateHasChanged();
    }

