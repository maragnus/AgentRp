            return Task.CompletedTask;

        var mode = HasDraftText ? StoryScenePostMode.RespondGuidedAi : StoryScenePostMode.RespondAutomaticAi;
        return PostAsAsync(mode, _chat.SelectedSpeaker.CharacterId, AutoselectAuthorKey, null);
    }

    private async Task PostAsAsync(StoryScenePostMode mode, Guid? speakerCharacterId, string? submittingAuthorKey, StoryTurnShape? requestedTurnShape)
    {
        if (_chat is null)
            return;

        _errorMessage = null;

        if (mode != StoryScenePostMode.Manual && !_chat.IsAiAvailable)
        {
            _errorMessage = "This chat does not currently have an AI provider configured.";
            return;
        }

        if (RequiresGuidance(mode) && !HasDraftText)
        {
            _errorMessage = mode == StoryScenePostMode.Manual
                ? "Enter a message before posting."
                : "Enter a guidance prompt before generating the message.";
            return;
        }

        if (HasRunningSceneProcess)
        {
            _errorMessage = "Stop the active scene generation before starting another one.";
            return;
        }

        _submittingMode = mode;
        _submittingAuthorKey = submittingAuthorKey;
        _submittingTurnShape = requestedTurnShape;
        _isSubmitting = true;
        var retryBranchMessageId = _retryBranchMessageId;
        var retrySourceMessageId = retryBranchMessageId ?? _retrySourceMessageId;

        try
        {
            await StorySceneChatService.PostMessageAsync(
                new PostStorySceneMessage(
                    _chat.ThreadId,
                    speakerCharacterId,
                    mode,
                    mode == StoryScenePostMode.Manual ? _draftText : null,
                    UsesGuidance(mode) ? _draftText : null,
                    retrySourceMessageId,
                    requestedTurnShape),
                mode == StoryScenePostMode.Manual ? null : HandleMessageStreamUpdateAsync,
                CancellationToken.None);

            if (retryBranchMessageId.HasValue)
                await DeleteRetryBranchCopyAsync(retryBranchMessageId.Value);

            if (!IgnoresDraft(mode))
                _draftText = string.Empty;
            ClearRetryState(clearDraft: false);
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
        }
        catch (OperationCanceledException)
        {
            if (mode != StoryScenePostMode.Manual)
            {
                await LoadChatAsync(_chat.ThreadId);
                ClearStreamedMessageContent();
            }

            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Posting scene message failed for chat {ThreadId}.", _chat.ThreadId);
            if (mode != StoryScenePostMode.Manual)
            {
                await LoadChatAsync(_chat.ThreadId);
                ClearStreamedMessageContent();
            }

            var fallbackMessage = mode == StoryScenePostMode.Manual
                ? "Posting the manual scene message failed."
                : "Generating the scene message failed.";
            _errorMessage = UserFacingErrorMessageBuilder.Build(fallbackMessage, exception);
        }
        finally
        {
            _isSubmitting = false;
            _submittingMode = null;
            _submittingAuthorKey = null;
            _submittingTurnShape = null;
        }
    }

    private async Task BeginRetryAsync(StorySceneMessageView message)
    {
        if (_chat is null || IsSceneInteractionLocked || !CanRetryMessage(message))
            return;

        _isSubmitting = true;
        _startingRetryMessageId = message.MessageId;
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            CancelAppearanceEdit();
            ClearRetryState(clearDraft: false);

            var branch = await StorySceneChatService.CreateBranchAsync(
                new BranchStorySceneMessage(_chat.ThreadId, message.MessageId, message.Content),
                CancellationToken.None);

            _retrySourceMessageId = message.MessageId;
            _retryBranchMessageId = branch.MessageId;
            _retrySpeakerName = message.CanonicalSpeakerName;
            _draftText = BuildRetryDraftText(message);

            await StorySceneChatService.SelectSpeakerAsync(_chat.ThreadId, message.SpeakerCharacterId, CancellationToken.None);
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Preparing retry from story scene message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            ClearRetryState(clearDraft: false);
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Preparing retry for '{message.CanonicalSpeakerName}' failed.", exception);
        }
        finally
        {
            _isSubmitting = false;
            _startingRetryMessageId = null;
        }
    }

    private async Task CancelRetryAsync()
    {
        if (_chat is null)
        {
            ClearRetryState(clearDraft: false);
            return;
        }

        var retryBranchMessageId = _retryBranchMessageId;
        if (!retryBranchMessageId.HasValue)
        {
            ClearRetryState(clearDraft: false);
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            await DeleteRetryBranchCopyAsync(retryBranchMessageId.Value);

            ClearRetryState(clearDraft: true);
            await LoadChatAsync(_chat.ThreadId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Canceling retry branch {MessageId} failed for chat {ThreadId}.", retryBranchMessageId, _chat.ThreadId);
            _errorMessage = UserFacingErrorMessageBuilder.Build("Canceling the retry branch failed.", exception);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteRetryBranchCopyAsync(Guid retryBranchMessageId)
    {
        if (_chat is null)
            return;

        await StorySceneChatService.DeleteMessageAsync(
            new DeleteStorySceneMessage(_chat.ThreadId, retryBranchMessageId, StorySceneDeleteMode.Branch),
            CancellationToken.None);
    }

    private void ClearRetryState(bool clearDraft)
    {
        _retrySourceMessageId = null;
        _retryBranchMessageId = null;
        _retrySpeakerName = null;
        _startingRetryMessageId = null;

        if (clearDraft)
            _draftText = string.Empty;
    }

    private void ClearStaleRetryState()
    {
        if (!_retrySourceMessageId.HasValue)
            return;

        var retryMessageId = _retryBranchMessageId ?? _retrySourceMessageId;
        var retryMessageIsInTranscript = retryMessageId.HasValue
            && _chat?.Transcript.Any(x => x.Message?.MessageId == retryMessageId.Value) == true;
        if (retryMessageIsInTranscript)
            return;

        ClearRetryState(clearDraft: false);
    }

    private bool CanRetryMessage(StorySceneMessageView message) =>
        !_retrySourceMessageId.HasValue
        && message.Process?.Status != ProcessRunStatus.Running;

    private bool CanRegenerateProse(StorySceneMessageView message) =>
        HasReusableSavedPlan(message);

    private bool CanEditSavedPlan(StorySceneMessageView message) =>
        HasReusableSavedPlan(message);

    private static bool HasReusableSavedPlan(StorySceneMessageView message) =>
        message.GenerationMode != StoryScenePostMode.Manual
        && message.Process?.Status != ProcessRunStatus.Running
        && message.Process?.Context is { GenerationContext: not null, Appearance: not null, Planner: not null };

    private async Task RegenerateProseAsync(StorySceneMessageView message)
    {
        if (_chat is null || IsSceneInteractionLocked || !CanRegenerateProse(message))
            return;

        _isSubmitting = true;
        _regeneratingProseMessageId = message.MessageId;
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            ClearRetryState(clearDraft: false);

            await RegenerateProseFromSavedPlanAsync(message);
        }
        catch (OperationCanceledException)
        {
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Regenerating prose from story scene message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = UserFacingErrorMessageBuilder.Build("Regenerating prose failed.", exception);
        }
        finally
        {
            _isSubmitting = false;
            _regeneratingProseMessageId = null;
        }
    }

    private async Task ChangeTurnShapeAndRegenerateAsync(StorySceneMessageView message, StoryTurnShape turnShape)
    {
        if (_chat is null || IsSceneInteractionLocked || !CanRegenerateProse(message) || !CanEditSavedPlan(message))
            return;

        var planner = message.Process?.Context?.Planner;
        if (planner is null || planner.TurnShape == turnShape)
            return;

        _isSubmitting = true;
        _changingTurnShapeMessageId = message.MessageId;
        _changingTurnShapeValue = turnShape;
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            CancelAppearanceEdit();
            ClearRetryState(clearDraft: false);

            await RegenerateProseFromSavedPlanAsync(message, BuildPlannerWithTurnShape(planner, message, turnShape));
        }
        catch (OperationCanceledException)
        {
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Changing the turn shape to {TurnShape} and regenerating prose from story scene message {MessageId} failed for chat {ThreadId}.", turnShape, message.MessageId, _chat.ThreadId);
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = UserFacingErrorMessageBuilder.Build($"Changing the turn shape to {FormatTurnShapeOption(turnShape)} and regenerating prose failed.", exception);
        }
        finally
        {
            _isSubmitting = false;
            _changingTurnShapeMessageId = null;
            _changingTurnShapeValue = null;
        }
    }

    private async Task RegenerateProseFromSavedPlanAsync(
        StorySceneMessageView message,
        StoryMessagePlannerResult? plannerOverride = null)
    {
        if (_chat is null)
            return;

        await StorySceneChatService.RegenerateProseAsync(
            new RegenerateStorySceneProse(_chat.ThreadId, message.MessageId, plannerOverride),
            HandleMessageStreamUpdateAsync,
            CancellationToken.None);

        await LoadChatAsync(_chat.ThreadId);
        ClearStreamedMessageContent();
    }

    private static StoryMessagePlannerResult BuildPlannerWithTurnShape(
        StoryMessagePlannerResult planner,
        StorySceneMessageView message,
        StoryTurnShape turnShape) =>
        new(
            turnShape,
            planner.Beat,
            planner.Intent,
            planner.ImmediateGoal,
            planner.WhyNow,
            planner.ChangeIntroduced,
            message.PrivateIntent ?? planner.PrivateIntent,
            planner.NarrativeGuardrails,
            planner.ContentGuardrails);

    private async Task ChangeMessageSpeakerAsync(StorySceneMessageView message, StorySceneSpeakerView author)
    {
        if (_chat is null || IsSceneInteractionLocked || IsCurrentMessageAuthor(message, author.CharacterId))
            return;

        _isSubmitting = true;
        _reassigningMessageId = message.MessageId;
        _reassigningAuthorKey = BuildAuthorKey(author.CharacterId);
        _errorMessage = null;

        try
        {
            CancelInlineEdit();
            ClearRetryState(clearDraft: false);

            if (ShouldRegenerateAfterSpeakerChange(message))
            {
                await StorySceneChatService.PostMessageAsync(
                    new PostStorySceneMessage(
                        _chat.ThreadId,
                        author.CharacterId,
                        ResolveSpeakerChangeRegenerationMode(message.GenerationMode),
                        null,
                        message.Process?.Context?.GuidancePrompt,
                        message.MessageId,
                        ResolveSpeakerChangeTurnShapePreference(message)),
                    HandleMessageStreamUpdateAsync,
                    CancellationToken.None);
                ClearStreamedMessageContent();
            }
            else
            {
                await StorySceneChatService.ChangeMessageSpeakerAsync(
                    new ChangeStorySceneMessageSpeaker(_chat.ThreadId, message.MessageId, author.CharacterId),
                    CancellationToken.None);
            }

            await LoadChatAsync(_chat.ThreadId);
        }
        catch (OperationCanceledException)
        {
            await LoadChatAsync(_chat.ThreadId);
            ClearStreamedMessageContent();
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Changing the author for story scene message {MessageId} failed for chat {ThreadId}.", message.MessageId, _chat.ThreadId);
            _errorMessage = UserFacingErrorMessageBuilder.Build("Changing the author for this scene message failed.", exception);
        }
        finally
        {
            _isSubmitting = false;
            _reassigningMessageId = null;
            _reassigningAuthorKey = null;
        }
    }

    private static bool IsCurrentMessageAuthor(StorySceneMessageView message, Guid? characterId) =>
        characterId.HasValue
            ? message.SpeakerCharacterId == characterId.Value && !message.IsNarrator
            : message.IsNarrator && !message.SpeakerCharacterId.HasValue;

    private static bool ShouldRegenerateAfterSpeakerChange(StorySceneMessageView message) =>
        message.GenerationMode != StoryScenePostMode.Manual
        && HasReusableSavedPlan(message);

    private static StoryScenePostMode ResolveSpeakerChangeRegenerationMode(StoryScenePostMode mode) => mode switch
    {
        StoryScenePostMode.RespondGuidedAi => StoryScenePostMode.GuidedAi,
        StoryScenePostMode.RespondAutomaticAi => StoryScenePostMode.AutomaticAi,
        _ => mode
    };

    private static StoryTurnShape? ResolveSpeakerChangeTurnShapePreference(StorySceneMessageView message) =>
        message.Process?.Context?.RequestedTurnShape
        ?? message.Process?.Context?.Planner?.TurnShape;

    private static string BuildAuthorKey(Guid? characterId) => characterId?.ToString("N") ?? "narrator";

    private static string BuildRetryDraftText(StorySceneMessageView message)
    {
        return message.GenerationMode switch
        {
            StoryScenePostMode.Manual => message.Content,
            StoryScenePostMode.GuidedAi or StoryScenePostMode.RespondGuidedAi => message.Process?.Context?.GuidancePrompt?.Trim() ?? string.Empty,
            StoryScenePostMode.AutomaticAi or StoryScenePostMode.RespondAutomaticAi => string.Empty,
            _ => string.Empty
        };
    }

    private void OpenPlanModal(StorySceneMessageView message)
    {
        if (!CanEditSavedPlan(message) || message.Process?.Context?.Planner is not { } planner)
            return;

        CancelInlineEdit();
        CancelAppearanceEdit();
        ClearRetryState(clearDraft: false);
        _editingPlanMessageId = message.MessageId;
        _editingPlanSpeakerName = message.CanonicalSpeakerName;
        _planDraftTurnShape = planner.TurnShape;
        _planDraftBeat = planner.Beat;
        _planDraftIntent = planner.Intent;
        _planDraftImmediateGoal = planner.ImmediateGoal;
        _planDraftWhyNow = planner.WhyNow;
        _planDraftChangeIntroduced = planner.ChangeIntroduced;
        _planDraftNarrativeGuardrails = string.Join(Environment.NewLine, planner.NarrativeGuardrails);
        _planDraftContentGuardrails = string.Join(Environment.NewLine, planner.ContentGuardrails);
        _planEditErrorMessage = null;
        _isPlanModalOpen = true;
    }

