    private static IReadOnlyList<StoryMessageProcessTextBlock> GetProcessStepBlocks(StorySceneProcessStepView step)
    {
        if (step.Artifact is null)
            return [];

        return step.Artifact.Inputs
            .Concat(step.Artifact.Outputs)
            .Where(block => !string.IsNullOrWhiteSpace(block.Content))
            .ToList();
    }

    private static bool CanCopyProcessStep(StorySceneProcessStepView step, IReadOnlyList<StoryMessageProcessTextBlock> blocks) =>
        !string.IsNullOrWhiteSpace(step.Detail) || blocks.Any(block => !string.IsNullOrWhiteSpace(block.Content));

    private async Task CopyProcessStepAsync(StorySceneProcessStepView step, IReadOnlyList<StoryMessageProcessTextBlock> blocks)
    {
        if (!CanCopyProcessStep(step, blocks))
            return;

        _errorMessage = null;
        _copyingProcessStepId = step.StepId;
        _copiedProcessStepId = null;
        _processStepCopyFeedbackCancellation?.Cancel();
        _processStepCopyFeedbackCancellation?.Dispose();
        _processStepCopyFeedbackCancellation = new CancellationTokenSource();

        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", BuildProcessStepMarkdownDocument(step, blocks));
            _copiedProcessStepId = step.StepId;
            _ = ClearProcessStepCopyFeedbackAsync(step.StepId, _processStepCopyFeedbackCancellation.Token);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Copying {StepTitle} process step markdown failed.", step.Title);
            UserFeedbackService.ShowBackgroundError(exception, $"Copying the {step.Title} process step failed.", "Copy Failed");
        }
        finally
        {
            _copyingProcessStepId = null;
        }
    }

    private static string BuildProcessStepMarkdownDocument(StorySceneProcessStepView step, IReadOnlyList<StoryMessageProcessTextBlock> blocks)
    {
        var builder = new StringBuilder();

        if (blocks.Count == 0)
            AppendMarkdownSection(builder, step.Title, step.Detail);

        foreach (var block in blocks)
            AppendMarkdownSection(builder, block.Title, block.Content);

        return builder.ToString().Trim();
    }

    private static void AppendMarkdownSection(StringBuilder builder, string title, string content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return;

        if (builder.Length > 0)
            builder.AppendLine();

        builder.Append("# ");
        builder.AppendLine(title.Trim());
        builder.AppendLine();
        builder.AppendLine(content.Trim());
    }

    private async Task ClearProcessStepCopyFeedbackAsync(Guid stepId, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(1.5), cancellationToken);

            if (_copiedProcessStepId == stepId)
                _copiedProcessStepId = null;

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

