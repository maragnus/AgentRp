    private Task PostRespondAsAsync(StorySceneSpeakerView author)
    {
        var mode = HasDraftText ? StoryScenePostMode.GuidedAi : StoryScenePostMode.AutomaticAi;
        return PostAsAsync(mode, author.CharacterId, BuildAuthorKey(author.CharacterId), null);
    }

    private Task PostRespondAutoselectAsync()
    {
