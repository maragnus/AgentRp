    private async Task HandleMessageStreamUpdateAsync(StorySceneMessageStreamUpdate update, CancellationToken cancellationToken)
    {
        if (_chat is null || _chat.ThreadId != update.ThreadId)
            return;

        await InvokeAsync(async () =>
        {
            if (_chat is null || _chat.ThreadId != update.ThreadId)
                return;

            if (!_chat.Transcript.Any(x => x.Message?.MessageId == update.MessageId))
                await LoadChatAsync(update.ThreadId);

            if (string.IsNullOrWhiteSpace(update.Content))
                _streamedMessageContent.Remove(update.MessageId);
            else
                _streamedMessageContent[update.MessageId] = update.Content;

            ScheduleChatLogScrollToBottom();
            StateHasChanged();
        });
    }

