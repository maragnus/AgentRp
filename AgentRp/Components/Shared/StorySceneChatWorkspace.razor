    private string BuildMessageCardClass(StorySceneMessageView message)
    {
        var classes = new List<string> { "story-scene-message", "app-message-card" };

        if (message.IsNarrator)
            classes.Add("ms-lg-3");
        else if (message.IsSelectedSpeaker)
            classes.Add("ms-lg-5");
        if (_selectedMessageId == message.MessageId)
            classes.Add("is-selected");
        if (_editingMessageId == message.MessageId)
