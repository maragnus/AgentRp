    private Task StopSceneRunAsync(Guid runId)
    {
        if (!_stoppingRunIds.Add(runId))
            return Task.CompletedTask;

        if (ModelOperationRegistry.TryCancel(runId))
        {
            StateHasChanged();
            return Task.CompletedTask;
        }

        _stoppingRunIds.Remove(runId);
        return Task.CompletedTask;
    }

    private void SyncStoppingRuns()
    {
        var runningRunIds = _chat?.Transcript
            .Select(x => x.Message?.Process)
            .Where(x => x?.Status == ProcessRunStatus.Running)
            .Select(x => x!.RunId)
            .ToHashSet()
            ?? [];
        _stoppingRunIds.RemoveWhere(runId => !runningRunIds.Contains(runId));
    }

