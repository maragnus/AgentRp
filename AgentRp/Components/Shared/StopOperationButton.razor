<BusyButton Class="@Class"
            OnClick="OnClick"
            IsBusy="@IsStopping"
            BusyText=""
            ShowBusyText="false"
            Disabled="@Disabled"
            title="@Title"
            aria-label="@Title">
    <i class="fa-regular fa-circle-stop @(ShowText ? "me-2" : string.Empty)" aria-hidden="true"></i>
    @if (ShowText)
    {
        <span>Stop</span>
    }
</BusyButton>

@code {
    [Parameter]
    public string Class { get; set; } = "btn btn-outline-danger";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool IsStopping { get; set; }

    [Parameter]
    public bool ShowText { get; set; }

    [Parameter]
    public string Title { get; set; } = "Stop the active model operation";

    [Parameter]
    public EventCallback OnClick { get; set; }
}
