@inject IStoryImageService StoryImageService
@inject ILogger<StoryImageGenerationModal> Logger

<AppModal IsOpen="IsOpen"
          Title="Generate Image"
          DialogClass="modal-xl modal-dialog-scrollable modal-fullscreen-sm-down"
          OnClose="CloseAsync"
          CloseDisabled="@_isGenerating">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="d-flex align-items-center gap-3 py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>Loading image tools...</span>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                <InlineAlert Message="@_errorMessage" />

                @if (_dialog is not null && _dialog.ImageModels.Count == 0)
                {
                    <div class="alert alert-warning mb-0">
                        Enable an OpenAI or Grok image model in AI Providers before generating images.
                    </div>
                }

                <div class="row g-3 align-items-start">
                    <div class="col-lg-5">
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <label class="form-label" for="@_modelInputId">Image Model</label>
                                <select id="@_modelInputId" class="form-select" disabled="@IsBusy" @bind="_selectedModelIdText">
                                    <option value="">No image model</option>
                                    @foreach (var model in _dialog?.ImageModels ?? [])
                                    {
                                        <option @key="model.ModelId" value="@model.ModelId">@model.Name (@model.ProviderName)</option>
                                    }
                                </select>
                            </div>

                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label" for="@_sizeInputId">Size</label>
                                    <select id="@_sizeInputId" class="form-select" disabled="@IsBusy" @bind="_size">
                                        <option value="1024x1024">Square</option>
                                        <option value="1536x1024">Landscape</option>
                                        <option value="1024x1536">Portrait</option>
                                        <option value="auto">Auto</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="@_qualityInputId">Quality</label>
                                    <select id="@_qualityInputId" class="form-select" disabled="@IsBusy" @bind="_quality">
                                        <option value="auto">Auto</option>
                                        <option value="low">Low</option>
                                        <option value="medium">Medium</option>
                                        <option value="high">High</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="@_fidelityInputId">Refs</label>
                                    <select id="@_fidelityInputId" class="form-select" disabled="@IsBusy" @bind="_referenceFidelity">
                                        <option value="low">Low</option>
                                        <option value="high">High</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label class="form-label" for="@_promptInputId">Prompt</label>
                                <textarea id="@_promptInputId" class="form-control" rows="4" disabled="@IsBusy" @bind="_prompt"></textarea>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_reviewedFinalPrompt))
                            {
                                <div class="border-top pt-3">
                                    <label class="form-label" for="@_reviewPromptInputId">Prompt Sent to Image Model</label>
                                    <textarea id="@_reviewPromptInputId" class="form-control" rows="6" disabled="@IsBusy" @bind="_reviewedFinalPrompt"></textarea>
                                    <div class="d-flex justify-content-end mt-2">
                                        <BusyButton Class="btn btn-outline-primary btn-sm"
                                                    IsBusy="_isGenerating"
                                                    Disabled="@(string.IsNullOrWhiteSpace(_reviewedFinalPrompt) || IsBusy)"
                                                    BusyText="Retrying..."
                                                    OnClick="RetryReviewedPromptAsync">
                                            <i class="fa-regular fa-rotate-right me-2" aria-hidden="true"></i>
                                            Retry
                                        </BusyButton>
                                    </div>
                                </div>
                            }

                            @if (_dialog is not null)
                            {
                                <div>
                                    <div class="fw-semibold mb-2">Story Entities</div>
                                    <div class="list-group app-image-picker-list">
                                        @foreach (var entity in _dialog.Entities)
                                        {
                                            var key = BuildEntityKey(entity.EntityKind, entity.EntityId);
                                            <label @key="key" class="list-group-item d-flex align-items-start gap-3">
                                                <input class="form-check-input mt-1" type="checkbox" checked="@_selectedEntityKeys.Contains(key)" disabled="@IsBusy" @onchange="args => ToggleEntity(entity, args)" />
                                                <StoryAvatar Name="@entity.Name"
                                                             ImageUrl="@entity.PrimaryImageUrl"
                                                             Crop="@entity.PrimaryImageCrop"
                                                             Class="app-story-avatar flex-shrink-0" />
                                                <span class="min-w-0">
                                                    <span class="fw-semibold d-block text-truncate">@entity.Name</span>
                                                    <span class="small text-body-secondary">@entity.EntityKind</span>
                                                </span>
                                            </label>
                                        }
                                    </div>
                                </div>

                                <div>
                                    <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                                        <div class="fw-semibold">Reference Images</div>
                                        <div class="form-check form-switch mb-0">
                                            <input id="@_showRecentInputId" class="form-check-input" type="checkbox" role="switch" disabled="@IsBusy" @bind="_showRecentReferences" />
                                            <label class="form-check-label small" for="@_showRecentInputId">Show recent</label>
                                        </div>
                                    </div>

                                    @if (FilteredReferenceImages.Count == 0)
                                    {
                                        <div class="small text-body-secondary">No reference images match the selected entities.</div>
                                    }
                                    else
                                    {
                                        <div class="row row-cols-3 g-2 app-image-picker-list">
                                            @foreach (var image in FilteredReferenceImages)
                                            {
                                                <div @key="image.ImageId" class="col">
                                                    <div class="card h-100">
                                                        <button type="button"
                                                                class="btn p-0 text-start"
                                                                title="@image.Title"
                                                                aria-label="@($"Preview {image.Title}")"
                                                                disabled="@IsBusy"
                                                                @onclick="() => OpenReferenceDetail(image)">
                                                            <img src="@image.ImageUrl" class="card-img-top app-story-image-thumb" alt="@image.Title" />
                                                        </button>
                                                        <div class="card-body p-2">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" checked="@_referenceImageIds.Contains(image.ImageId)" disabled="@IsBusy" @onchange="args => ToggleReference(image.ImageId, args)" />
                                                                <label class="form-check-label small text-truncate d-block" title="@image.Title">@image.Title</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="d-flex flex-column gap-2">
                            <div class="fw-semibold">Generated Images</div>

                            @if (SelectedPreview is null)
                            {
                                @if (_isGenerating)
                                {
                                    <button type="button"
                                            class="btn border rounded d-flex align-items-center justify-content-center app-generated-image-preview text-body-secondary w-100 p-0"
                                            title="Open image generation details"
                                            aria-label="Open image generation details"
                                            @onclick="OpenGeneratingDetail">
                                        <div class="text-center small px-3">
                                            @if (string.IsNullOrWhiteSpace(_generationPreviewDataUrl))
                                            {
                                                <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                            }
                                            else
                                            {
                                                <img src="@_generationPreviewDataUrl" class="img-fluid rounded mb-2 app-generated-image-progress-preview" alt="Image generation preview" />
                                            }
                                            <div>@_generationProgressMessage</div>
                                        </div>
                                    </button>
                                }
                                else
                                {
                                    <div class="border rounded d-flex align-items-center justify-content-center app-generated-image-preview text-body-secondary">
                                        <div class="text-center small">
                                            <i class="fa-regular fa-image fs-2 d-block mb-2" aria-hidden="true"></i>
                                            <span>Generated images appear here.</span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <button type="button"
                                        class="btn p-0 text-start border rounded overflow-hidden"
                                        title="Open generated image details"
                                        aria-label="Open generated image details"
                                        disabled="@IsBusy"
                                        @onclick="() => OpenGeneratedDetail(SelectedPreview)">
                                    <img src="@SelectedPreview.ImageUrl" class="img-fluid w-100 app-generated-image-preview" alt="Selected generated image" />
                                </button>
                                @if (!string.IsNullOrWhiteSpace(SelectedPreview.Rationale))
                                {
                                    <div class="small text-body-secondary text-truncate" title="@SelectedPreview.Rationale">@SelectedPreview.Rationale</div>
                                }
                                @if (_isGenerating && !string.IsNullOrWhiteSpace(_generationProgressMessage))
                                {
                                    <div class="small text-body-secondary">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        @_generationProgressMessage
                                    </div>
                                }
                            }

                            @if (_previewResults.Count > 0)
                            {
                                <div class="d-flex gap-2 overflow-auto pb-1">
                                    @foreach (var preview in _previewResults)
                                    {
                                        var isSelected = _selectedPreviewId == preview.ImageId;
                                        <button type="button"
                                                @key="preview.ImageId"
                                                class="btn p-0 border rounded flex-shrink-0 app-generated-image-thumb @(isSelected ? "border-primary border-2" : string.Empty)"
                                                title="Select generated image"
                                                aria-label="Select generated image"
                                                aria-pressed="@isSelected"
                                                disabled="@IsBusy"
                                                @onclick="() => SelectPreview(preview.ImageId)">
                                            <img src="@preview.ImageUrl" class="w-100 h-100 object-fit-cover rounded" alt="Generated image thumbnail" />
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="btn btn-outline-secondary" disabled="@_isGenerating" @onclick="CloseAsync">Close</button>
        <BusyButton Class="btn btn-outline-secondary"
                    IsBusy="_isSavingSettings"
                    Disabled="@IsBusy"
                    BusyText="Saving..."
                    OnClick="SaveSettingsAsync">
            <i class="fa-regular fa-floppy-disk me-2" aria-hidden="true"></i>
            Save Default
        </BusyButton>
        <BusyButton Class="btn btn-primary"
                    IsBusy="_isGenerating"
                    Disabled="@(_dialog is null || _dialog.ImageModels.Count == 0 || string.IsNullOrWhiteSpace(_prompt) || IsBusy)"
                    BusyText="Generating..."
                    OnClick="GenerateAsync">
            <i class="fa-regular fa-image me-2" aria-hidden="true"></i>
            @(_previewResults.Count == 0 ? "Generate" : "Generate More")
        </BusyButton>
        <BusyButton Class="btn btn-success"
                    IsBusy="_isSavingImage"
                    Disabled="@(_selectedPreviewId is null || IsBusy)"
                    BusyText="Saving..."
                    OnClick="SaveSelectedAsync">
            <i class="fa-regular fa-check me-2" aria-hidden="true"></i>
            @(GalleryMode ? "Save to Gallery" : "Save & Use")
        </BusyButton>
    </FooterContent>
</AppModal>

<AppModal IsOpen="@(_detailPreview is not null || _detailReference is not null || _isGeneratingDetailOpen)"
          Title="@BuildDetailTitle()"
          DialogClass="modal-lg modal-dialog-centered modal-dialog-scrollable modal-fullscreen-sm-down"
          OnClose="CloseDetailAsync">
    <ChildContent>
        @if (_isGeneratingDetailOpen)
        {
            <div class="d-flex flex-column gap-3">
                <div class="border rounded d-flex align-items-center justify-content-center app-generated-image-preview text-body-secondary">
                    <div class="text-center small px-3">
                        @if (string.IsNullOrWhiteSpace(_generationPreviewDataUrl))
                        {
                            <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                        }
                        else
                        {
                            <img src="@_generationPreviewDataUrl" class="img-fluid rounded mb-2 app-generated-image-progress-preview" alt="Image generation preview" />
                        }
                        <div>@_generationProgressMessage</div>
                    </div>
                </div>
                @RenderDetailSection("User Prompt", _prompt)
                @RenderDetailSection("Prompt", _generationFinalPrompt)
                @RenderDetailSection("Rationale", _generationRationale)
            </div>
        }
        else if (_detailPreview is not null)
        {
            <div class="d-flex flex-column gap-3">
                <img src="@_detailPreview.ImageUrl" class="img-fluid rounded" alt="Generated image" />
                @RenderDetailSection("User Prompt", _detailPreview.UserPrompt)
                @RenderDetailSection("Prompt", _detailPreview.FinalPrompt)
                @RenderDetailSection("Rationale", _detailPreview.Rationale)
            </div>
        }
        else if (_detailReference is not null)
        {
            <div class="d-flex flex-column gap-3">
                <img src="@_detailReference.ImageUrl" class="img-fluid rounded" alt="@_detailReference.Title" />
                <div class="small text-body-secondary">@_detailReference.CreatedUtc.ToShorthandDateWithRelativeDays()</div>
                @RenderDetailSection("User Prompt", _detailReference.UserPrompt)
                @RenderDetailSection("Prompt", _detailReference.FinalPrompt)
                @RenderDetailSection("Rationale", _detailReference.GenerationRationale)
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="btn btn-outline-secondary" @onclick="CloseDetailAsync">Close</button>
        @if (_detailReference is not null)
        {
            <button type="button" class="btn btn-outline-primary" @onclick="OpenReferenceCrop">
                <i class="fa-regular fa-crop-simple me-2" aria-hidden="true"></i>
                Crop
            </button>
        }
    </FooterContent>
</AppModal>

<StoryImageCropModal ThreadId="ThreadId"
                     IsOpen="@(_cropReference is not null)"
                     Image="@_cropReference"
                     OnSaved="HandleReferenceCropSavedAsync"
                     OnClose="CloseReferenceCropAsync" />

@code {
    [Parameter]
    public Guid ThreadId { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public StoryEntityKind? InitialEntityKind { get; set; }

    [Parameter]
    public Guid? InitialEntityId { get; set; }

    [Parameter]
    public string? InitialPrompt { get; set; }

    [Parameter]
    public string? InitialSize { get; set; }

    [Parameter]
    public bool IncludePrimaryReference { get; set; }

    [Parameter]
    public bool PickerMode { get; set; }

    [Parameter]
    public bool GalleryMode { get; set; }

    [Parameter]
    public EventCallback<StoryImageGenerationResult> OnGenerated { get; set; }

    [Parameter]
    public EventCallback<StoryImageReferenceView> OnImageSaved { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private readonly string _modelInputId = $"image-model-{Guid.NewGuid():N}";
    private readonly string _sizeInputId = $"image-size-{Guid.NewGuid():N}";
    private readonly string _qualityInputId = $"image-quality-{Guid.NewGuid():N}";
    private readonly string _fidelityInputId = $"image-fidelity-{Guid.NewGuid():N}";
    private readonly string _promptInputId = $"image-prompt-{Guid.NewGuid():N}";
    private readonly string _reviewPromptInputId = $"image-review-prompt-{Guid.NewGuid():N}";
    private readonly string _showRecentInputId = $"image-show-recent-{Guid.NewGuid():N}";
    private bool _wasOpen;
    private bool _isLoading;
    private bool _isGenerating;
    private bool _isSavingImage;
    private bool _isSavingSettings;
    private bool _showRecentReferences;
    private string? _errorMessage;
    private StoryImageGenerationDialogView? _dialog;
    private string _selectedModelIdText = string.Empty;
    private string _size = "1024x1024";
    private string _quality = "auto";
    private string _referenceFidelity = "low";
    private string _prompt = string.Empty;
    private string? _reviewedFinalPrompt;
    private string? _generationPreviewDataUrl;
    private string? _generationFinalPrompt;
    private string? _generationRationale;
    private string _generationProgressMessage = string.Empty;
    private bool _useReviewedPromptForNextGeneration;
    private bool _isGeneratingDetailOpen;
    private readonly HashSet<string> _selectedEntityKeys = [];
    private readonly HashSet<Guid> _referenceImageIds = [];
    private readonly List<StoryImagePreviewResult> _previewResults = [];
    private Guid _transientSessionId = Guid.NewGuid();
    private Guid? _selectedPreviewId;
    private StoryImagePreviewResult? _detailPreview;
    private StoryImageReferenceView? _detailReference;
    private StoryImageReferenceView? _cropReference;

    private bool IsBusy => _isLoading || _isGenerating || _isSavingImage || _isSavingSettings;

    private StoryImagePreviewResult? SelectedPreview => _previewResults.FirstOrDefault(x => x.ImageId == _selectedPreviewId);

    private IReadOnlyList<StoryImageReferenceView> FilteredReferenceImages =>
        _dialog?.ReferenceImages.Where(ShouldShowReferenceImage).ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _wasOpen = false;
            return;
        }

        if (_wasOpen)
            return;

        _wasOpen = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _previewResults.Clear();
        _transientSessionId = Guid.NewGuid();
        _selectedPreviewId = null;
        _detailPreview = null;
        _detailReference = null;
        _cropReference = null;
        _reviewedFinalPrompt = null;
        _generationPreviewDataUrl = null;
        _generationFinalPrompt = null;
        _generationRationale = null;
        _generationProgressMessage = string.Empty;
        _useReviewedPromptForNextGeneration = false;
        _isGeneratingDetailOpen = false;
        try
        {
            _dialog = await StoryImageService.GetGenerationDialogAsync(ThreadId, CancellationToken.None);
            _selectedModelIdText = _dialog.Settings.SelectedModelId?.ToString() ?? string.Empty;
            _size = string.IsNullOrWhiteSpace(InitialSize) || _isSavingSettings ? _dialog.Settings.Size : InitialSize;
            _quality = _dialog.Settings.Quality;
            _referenceFidelity = _dialog.Settings.ReferenceFidelity;
            _prompt = InitialPrompt ?? string.Empty;
            _selectedEntityKeys.Clear();
            _referenceImageIds.Clear();
            _showRecentReferences = false;

            if (InitialEntityKind.HasValue && InitialEntityId.HasValue)
            {
                var entity = _dialog.Entities.FirstOrDefault(x => x.EntityKind == InitialEntityKind.Value && x.EntityId == InitialEntityId.Value);
                if (entity is not null)
                {
                    _selectedEntityKeys.Add(BuildEntityKey(entity.EntityKind, entity.EntityId));
                    if (IncludePrimaryReference && entity.PrimaryImageId.HasValue)
                        _referenceImageIds.Add(entity.PrimaryImageId.Value);
                }
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Loading image generation dialog failed for chat {ThreadId}.", ThreadId);
            _errorMessage = UserFacingErrorMessageBuilder.Build("Loading image generation failed.", exception);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleEntity(StoryImageEntityOptionView entity, ChangeEventArgs args)
    {
        var key = BuildEntityKey(entity.EntityKind, entity.EntityId);
        if (args.Value is bool value && value)
            _selectedEntityKeys.Add(key);
        else
            _selectedEntityKeys.Remove(key);
    }

    private void ToggleReference(Guid imageId, ChangeEventArgs args)
    {
        if (args.Value is bool value && value)
            _referenceImageIds.Add(imageId);
        else
            _referenceImageIds.Remove(imageId);
    }

    private async Task SaveSettingsAsync()
    {
        _isSavingSettings = true;
        _errorMessage = null;
        try
        {
            await StoryImageService.SaveSettingsAsync(
                new ImageGenerationModelSettingsView(ParseGuidOrNull(_selectedModelIdText), _size, _quality, _referenceFidelity),
                CancellationToken.None);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving image generation defaults failed.");
            _errorMessage = UserFacingErrorMessageBuilder.Build("Saving image generation defaults failed.", exception);
        }
        finally
        {
            _isSavingSettings = false;
        }
    }

    private async Task GenerateAsync()
    {
        if (_dialog is null)
            return;

        _isGenerating = true;
        _errorMessage = null;
        try
        {
            await StoryImageService.SaveSettingsAsync(
                new ImageGenerationModelSettingsView(ParseGuidOrNull(_selectedModelIdText), _size, _quality, _referenceFidelity),
                CancellationToken.None);
            var selectedEntities = BuildSelectedEntities();
            _generationPreviewDataUrl = null;
            _generationFinalPrompt = null;
            _generationRationale = null;
            _generationProgressMessage = "Preparing image generation...";
            var reviewedFinalPrompt = _useReviewedPromptForNextGeneration ? _reviewedFinalPrompt : null;
            _useReviewedPromptForNextGeneration = false;
            var progress = new Progress<StoryImageGenerationProgress>(HandleGenerationProgress);
            var preview = await StoryImageService.GeneratePreviewAsync(
                new GenerateStoryImagePreview(
                    ThreadId,
                    _transientSessionId,
                    _prompt,
                    reviewedFinalPrompt,
                    selectedEntities,
                    _referenceImageIds.ToList(),
                    _size,
                    _quality,
                    _referenceFidelity),
                progress,
                CancellationToken.None);
            _previewResults.Insert(0, preview);
            _selectedPreviewId = preview.ImageId;
            _reviewedFinalPrompt = null;
            _isGeneratingDetailOpen = false;
        }
        catch (StoryImageGenerationBadRequestException exception)
        {
            Logger.LogError(exception, "Generating story image failed because the image model rejected the request for chat {ThreadId}.", ThreadId);
            _reviewedFinalPrompt = exception.FinalPrompt;
            _errorMessage = UserFacingErrorMessageBuilder.Build("Generating the story image failed.", exception);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Generating story image failed for chat {ThreadId}.", ThreadId);
            _errorMessage = UserFacingErrorMessageBuilder.Build("Generating the story image failed.", exception);
        }
        finally
        {
            _isGenerating = false;
            _generationProgressMessage = string.Empty;
            _generationPreviewDataUrl = null;
        }
    }

    private async Task RetryReviewedPromptAsync()
    {
        _useReviewedPromptForNextGeneration = true;
        await GenerateAsync();
    }

    private void HandleGenerationProgress(StoryImageGenerationProgress progress)
    {
        _generationProgressMessage = progress.Message;
        if (!string.IsNullOrWhiteSpace(progress.PreviewImageDataUrl))
            _generationPreviewDataUrl = progress.PreviewImageDataUrl;
        if (!string.IsNullOrWhiteSpace(progress.FinalPrompt))
            _generationFinalPrompt = progress.FinalPrompt;
        if (!string.IsNullOrWhiteSpace(progress.Rationale))
            _generationRationale = progress.Rationale;

        _ = InvokeAsync(StateHasChanged);
    }

    private void SelectPreview(Guid previewId) => _selectedPreviewId = previewId;

    private async Task SaveSelectedAsync()
    {
        if (_dialog is null || !_selectedPreviewId.HasValue)
            return;

        var selectedPreview = _previewResults.FirstOrDefault(x => x.ImageId == _selectedPreviewId.Value);
        if (selectedPreview is null)
            return;

        _isSavingImage = true;
        _errorMessage = null;
        try
        {
            var selectedEntities = BuildSelectedEntities();
            var setPrimaryForFirstEntity = !PickerMode && !GalleryMode && InitialEntityId.HasValue && selectedEntities.Count > 0;
            var image = await StoryImageService.SaveGeneratedImageAsync(
                new SaveGeneratedStoryImage(
                    ThreadId,
                    selectedPreview.ImageId,
                    _transientSessionId,
                    selectedEntities,
                    setPrimaryForFirstEntity),
                CancellationToken.None);

            if (OnImageSaved.HasDelegate)
                await OnImageSaved.InvokeAsync(image);

            if (OnGenerated.HasDelegate)
                await OnGenerated.InvokeAsync(new StoryImageGenerationResult(
                    image.ImageId,
                    image.ImageUrl,
                    image.FinalPrompt ?? selectedPreview.FinalPrompt,
                    image.GenerationRationale ?? selectedPreview.Rationale));
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Saving generated story image failed for chat {ThreadId}.", ThreadId);
            _errorMessage = UserFacingErrorMessageBuilder.Build("Saving the generated image failed.", exception);
        }
        finally
        {
            _isSavingImage = false;
        }
    }

    private async Task CloseAsync()
    {
        if (_isGenerating || _isSavingImage)
            return;

        await DiscardTransientImagesAsync();
        await OnClose.InvokeAsync();
    }

    private async Task DiscardTransientImagesAsync()
    {
        if (_previewResults.Count == 0)
            return;

        try
        {
            await StoryImageService.DiscardTransientImagesAsync(ThreadId, _transientSessionId, CancellationToken.None);
            _previewResults.Clear();
            _selectedPreviewId = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Discarding transient generated images failed for chat {ThreadId}.", ThreadId);
        }
    }

    private void OpenGeneratedDetail(StoryImagePreviewResult? preview)
    {
        if (preview is null)
            return;

        _detailReference = null;
        _isGeneratingDetailOpen = false;
        _detailPreview = preview;
    }

    private void OpenGeneratingDetail()
    {
        if (!_isGenerating)
            return;

        _detailPreview = null;
        _detailReference = null;
        _isGeneratingDetailOpen = true;
    }

    private void OpenReferenceDetail(StoryImageReferenceView image)
    {
        _detailPreview = null;
        _isGeneratingDetailOpen = false;
        _detailReference = image;
    }

    private Task CloseDetailAsync()
    {
        _detailPreview = null;
        _detailReference = null;
        _isGeneratingDetailOpen = false;
        return Task.CompletedTask;
    }

    private void OpenReferenceCrop()
    {
        _cropReference = _detailReference;
        _detailReference = null;
    }

    private Task HandleReferenceCropSavedAsync(StoryImageReferenceView image)
    {
        _cropReference = null;
        _detailReference = null;
        if (_dialog is not null)
        {
            _dialog = _dialog with
            {
                ReferenceImages = _dialog.ReferenceImages
                    .Select(x => x.ImageId == image.ImageId ? image : x)
                    .ToList()
            };
        }
        return Task.CompletedTask;
    }

    private Task CloseReferenceCropAsync()
    {
        _cropReference = null;
        return Task.CompletedTask;
    }

    private IReadOnlyList<StoryImageEntitySelection> BuildSelectedEntities()
    {
        if (_dialog is null)
            return [];

        return _dialog.Entities
            .Where(x => _selectedEntityKeys.Contains(BuildEntityKey(x.EntityKind, x.EntityId)))
            .Select(x => new StoryImageEntitySelection(x.EntityKind, x.EntityId))
            .ToList();
    }

    private bool ShouldShowReferenceImage(StoryImageReferenceView image) =>
        _showRecentReferences
        || _referenceImageIds.Contains(image.ImageId)
        || image.LinkedEntities.Any(x => _selectedEntityKeys.Contains(BuildEntityKey(x.EntityKind, x.EntityId)));

    private string BuildDetailTitle()
    {
        if (_detailReference is not null)
            return _detailReference.Title;

        if (_detailPreview is not null)
            return "Generated Image";

        if (_isGeneratingDetailOpen)
            return "Generating Image";

        return "Image";
    }

    private static RenderFragment RenderDetailSection(string title, string? value) => builder =>
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        builder.OpenElement(0, "div");
        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "fw-semibold mb-1");
        builder.AddContent(3, title);
        builder.CloseElement();
        builder.OpenElement(4, "div");
        builder.AddAttribute(5, "class", "small text-break");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string BuildEntityKey(StoryEntityKind entityKind, Guid entityId) => $"{entityKind}:{entityId:N}";

    private static Guid? ParseGuidOrNull(string? value) =>
        Guid.TryParse(value, out var id) ? id : null;
}
